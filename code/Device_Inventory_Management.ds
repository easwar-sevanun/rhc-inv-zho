	reports
	{
		kanban inventory_items_by_status
		{
			displayName = "Inventory Perpheral Item Status Report-BP"
			show all rows from inventory_items  [device_category == "PERIPHERAL" && Peripheral_Type.peripheral_type == "BP Machine"]  
			(
