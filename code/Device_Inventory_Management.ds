			kit_delete_action as "kit_delete_action"
			{
				type =  form
				form = kit

				record event = on delete

				on success
				{
					actions 
					{
						custom deluge script
						(
											// ── Reset Bag ──────────────────────────────────────
										if(input.bag1 != null)
										{
											bagRec = bags[ID == input.bag1];
											if(bagRec != null || bagRec.count() > 0)
											{
												bagRec.status="IN STOCK";
												bagRec.notes=bagRec.notes + " | Bag released: Kit " + input.kit_code + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy");
											}
										}
										// ── Reset Hub ──────────────────────────────────────
										if(input.hub_item1 != null)
										{
											hubRec = inventory_items[ID == input.hub_item1];
											if(hubRec.count() > 0)
											{
												hubRec.status="IN STOCK";
												hubRec.notes=hubRec.notes + " | Hub released: Kit " + input.kit_code + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy");
											}
										}
										/// ── Reset Peripherals ──────────────────────────────
										// ← fetch the live record
										kitRec = kit[ID == input.ID];
										if(kitRec.count() > 0)
										{
											kitRec.kit_status="DISMANDLED";
											for each  kt in kitRec.Kit_Items
											{
												// ← iterate from the fetched record, not input
												if(kt.inventory_items != null)
												{
													invItem = inventory_items[ID == kt.inventory_items.ID];
													if(invItem.count() > 0)
													{
														invItem.status="IN STOCK";
														invItem.notes=invItem.notes + " | Released: Kit " + input.kit_code + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy");
													}
												}
											}
										}
						)
					}
				}

			}
