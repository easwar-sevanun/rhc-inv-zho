	share_settings
	{
			"Device & SIM Lifecycle Manager"
			{
				name = "Device & SIM Lifecycle Manager"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Track and manage device hardware and firmware versions across inventory \n"
				ModulePermissions
				{
					kit_issues
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							kit_issues_by_status={"View","Edit","Delete"}
							kit_issues_address={"View","Edit","Delete"}
						}
					}
					hub_sim_assignments
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
					}
					device_models
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							device_models_Report={"View","Edit","Delete"}
						}
					}
					inventory_items
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							inventory_items_by_status={"View","Edit","Delete"}
						}
					}
					sim_cards
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							sim_cards_Report={"View","Edit","Delete"}
							sim_cards_by_status={"View","Edit","Delete"}
						}
					}
				}
			}
			"Read"
			{
