			peripheral_type1
			(
				type = picklist	
				displayname = "Peripheral Type"
				values  = Peripheral_Type.ID
    			displayformat = [peripheral_type]
				allow new entries
				[
					displayname = "Add New"
					set values
					(
						peripheral_type = input.peripheral_type1
					)
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			manufacturer
			(
    			type = text
