		form kit
		{
			displayname = "New Kit"
			success message = "Kit Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			kit_code
			(
    			type = text
				displayname = "Kit Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
			bag1
			(
				type = picklist	
				displayname = "Bag"
				values  = bags[status == "IN STOCK"].ID
    			displayformat = [bag_tag]
				allow new entries
				[
					displayname = "Add New"
					set values
					(
						bag_tag = input.bag1
					)
				]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			kit_status
			(
				type = picklist
				displayname = "Kit Status"
				values = {"AVAILABLE","ALLOCATED","EXTENDED","TO BE STERILIZED","RETURNED","PARTIAL RETURN","LOST","PARTIAL LOST","DAMAGED","PARTIAL DAMAGED","IN SERVICE","DISMANDLED"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			hub_item1
			(
				type = picklist	
				displayname = "Hub"
				values  = inventory_items[status == "IN STOCK" && device_category == "HUB"].ID
