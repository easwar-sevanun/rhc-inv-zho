			(
				type = picklist
				displayname = "Kit Status"
				values = {"AVAILABLE","ALLOCATED","EXTENDED","TO BE STERILIZED","RETURNED","PARTIAL RETURN","LOST","PARTIAL LOST","DAMAGED","PARTIAL DAMAGED","IN SERVICE","DISMANDLED","SERVICE PAUSED"}
				others option = true
