		blueprint
		{
    			kit_issue_and_return_process as "Kit Issue and Return Process"
    			{
        			type = Blueprint
        			form = kit_issues
        			start
        			{
            			start stage = "Kit Available"
            			chart data
            			{
                			from port : B
                			to port   : T3
                			position  : "0 0"
                			path      : [27.849999999999994,36.84,27.849999999999994,46.84,27.849999999999994,64.92,6.55552012222018,64.92,6.55552012222018,83,6.55552012222018,93]
            			}
        			}
        			stages
        			{
           			"Kit Assigned"
           			{
               			chart data
               			{
                   			position : "-273.33333333333326 170.00000000000003"
               			}
           			}
           			"Kit Ready to Use"
           			{
               			chart data
               			{
                   			position : "-537.5000000000001 242.49999999999994"
               			}
           			}
           			"Kit Not Picked Up"
           			{
