	variables
	{
		thisapp.variables.EMR.EMR_BASE_URL = "https://emrtest.sevanun.com";
		thisapp.variables.EMR.EMR_BEARER_TOKEN = "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkBnbWFpbC5jb20iLCJpYXQiOjE3NzMxMzM1NjcsImV4cCI6MTc3MzIxOTk2N30.D4ALk-zfe0cbZb4DN7is8zx68Z90LitMXWhYm4iOXWU";
	}

		 functions
		 {
			 Deluge
			 {
				 map fn_assign_or_replace_sim(string hubScan, string simScan, date activatedOn, string reason, string notes)
                 {
                 	res = Map();
                 	res.put("success",true);
                 	res.put("message","");
                 	// resolve hub
                 	hub = inventory_items[internal_barcode == hubScan || serial_number == hubScan];
                 	if(hub == null || hub.device_category != "HUB")
                 	{
                 		res.put("success",false);
                 		res.put("message","Hub not found or not a HUB.");
                 		return res;
                 	}
                 	// resolve SIM
                 	sim = sim_cards[sim_number == simScan];
                 	if(sim == null)
                 	{
                 		sim = sim_cards[iccid == simScan];
                 	}
                 	if(sim == null)
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM not found.");
                 		return res;
                 	}
                 	if(!(sim.status == "AVAILABLE" || sim.status == "ACTIVE"))
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM status must be AVAILABLE or ACTIVE.");
                 		return res;
                 	}
                 	// block SIM active elsewhere
                 	other = hub_sim_assignments[sim_card == sim.ID];
                 	if(other != null && other.hub_item.ID != hub.ID)
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM already assigned to another hub.");
                 		return res;
                 	}
                 	// close existing SIM on hub
                 	existing = hub_sim_assignments[hub_item == hub.ID];
                 	if(existing != null)
                 	{
                 		oldSim = sim_cards[ID == existing.sim_card];
                 		if(oldSim != null)
                 		{
                 			oldSim.status="AVAILABLE";
                 		}
                 		delete from hub_sim_assignments[ID == existing.ID];
                 	}
                 	if(reason != null && reason != "")
                 	{
                 		cr = reason;
                 	}
                 	else
                 	{
                 		cr = "INITIAL";
                 	}
                 	// create new assignment
                 	insert into hub_sim_assignments
                 	[
                 		hub_item=hub.ID
                 		sim_card=sim.ID
                 		assigned_on=zoho.currenttime
                 		notes=notes
                 		assigned_by=zoho.loginuser
                 		Added_User=zoho.loginuser
                 	]
                 	// update SIM master
                 	simRec = sim_cards[ID == sim.ID];
                 	if(simRec != null)
                 	{
                 		simRec.status="IN KIT";
                 		if(sim.activation_date == null && activatedOn != null)
                 		{
                 			simRec.activation_date=activatedOn;
                 		}
                 	}
                 	//sim_cards[ID == sim.ID].status = "ACTIVE";
                 	// update hub cache
                 	hubRec = inventory_items[ID == hub.ID];
                 	if(hubRec != null)
                 	{
                 		hubRec.active_sim_number=sim.ID;
                 	}
                 	res.put("success",true);
                 	res.put("message","SIM assigned / replaced successfully.");
                 	return res;
                 }
				 string fn_generate_code(string prefix, int seq)
                 {
                 	return prefix + "-" + "000000".subString(0,6 - seq.toString().length()) + seq;
                 }
				 map fn_getapitoken()
                 {
                 	baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 	retmsg = Map();
                 	retmsg.put("code",200);
                 	retmsg.put("msg","Success");
                 	if(baseUrlRec.count() == 0)
                 	{
                 		retmsg.put("code",1);
                 		retmsg.put("msg","EMR configuration missing. Please check App Config.");
                 		return retmsg;
                 	}
                 	else
                 	{
                 		emrBase = baseUrlRec.config_value;
                 		refreshTokenUpdate = App_Config[config_key == "EMR_REFRESH_TOKEN"];
                 		loginPayload = Map();
                 		if(refreshTokenUpdate == null || refreshTokenUpdate.count() == 0 || refreshTokenUpdate.config_value == null || refreshTokenUpdate.config_value.trim() == "")
                 		{
                 			apiUrl = emrBase + "/api/auth/login";
                 		}
                 		else
                 		{
                 			loginPayload.put("refreshToken",refreshTokenUpdate.config_value);
                 			apiUrl = emrBase + "/api/auth/refreshlogin";
                 		}
                 		loginPayload.put("allowRemoteCare",true);
                 		loginPayload.put("password",App_Config[config_key == "EMR_PASSWORD"].config_value);
                 		loginPayload.put("roleType","GENERAL");
                 		loginPayload.put("username",App_Config[config_key == "EMR_USERNAME"].config_value);
                 		headersMap = Map();
                 		headersMap.put("accept","*/*");
                 		headersMap.put("Content-Type","application/json");
                 		response = invokeurl
                 		[
                 			url :apiUrl
                 			type :POST
                 			body:loginPayload.toString()
                 			headers:headersMap
                 		];
                 		responseMap = response.toMap();
                 		if(responseMap.containKey("token") || responseMap.get("status") == 200 || responseMap.get("status") == 201)
                 		{
                 			bearerToken = responseMap.get("token");
                 			if(bearerToken == null || bearerToken.size() == 0)
                 			{
                 				retmsg.put("code",1);
                 				retmsg.put("msg","Login failed");
                 				return retmsg;
                 			}
                 			tokenUpdate = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 			tokenUpdate.config_value=bearerToken;
                 			refreshToken = responseMap.get("refreshToken");
                 			refreshTokenUpdate = App_Config[config_key == "EMR_REFRESH_TOKEN"];
                 			if(refreshToken == null || refreshToken.size() == 0)
                 			{
                 				retmsg.put("code",1);
                 				retmsg.put("msg","Login failed");
                 				return retmsg;
                 			}
                 			refreshTokenUpdate.config_value=refreshToken;
                 		}
                 		else
                 		{
                 			retmsg.put("code",responseMap.get("statusCode"));
                 			retmsg.put("msg",responseMap.get("data"));
                 			retmsg.put("addmsg","|" + apiUrl + "|" + refreshTokenUpdate.config_value);
                 			retmsg.put("dump",responseMap);
                 			return retmsg;
                 		}
                 	}
                 	return retmsg;
                 }
				 map fn_getbearertoken()
                 {
                 	tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 	retmsg = Map();
                 	retmsg.put("code",200);
                 	retmsg.put("msg","Success");
                 	if(tokenRec.count() == 0)
                 	{
                 		retstatus = thisapp.fn_getapitoken();
                 		if(retstatus.get("msg") == "Success")
                 		{
                 			tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 			rec = insert into App_Config
                 			[
                 				config_key="EMR_BEARER_TOKEN"
                 				config_value=tokenRec.config_value
                 				Added_User=zoho.loginuser
                 			];
                 			retmsg.put("token",tokenRec.config_value);
                 		}
                 		else
                 		{
                 			retmsg.put("code",1);
                 			retmsg.put("msg",retstatus.get("msg"));
                 		}
                 	}
                 	else
                 	{
                 		retmsg.put("token",tokenRec.config_value);
                 	}
                 	return retmsg;
                 }
				 string fn_kit_offboard(int distribution_id)
                 {
                 	kd = kit_issues[ID == distribution_id];
                 	kitRec = kit[ID = kd.kit];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.notes="Offboarding: Kit " + kitRec.ID + " onboarded on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + kitRec.notes;
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			tokenRec = thisapp.fn_getbearertoken();
                 			if(tokenRec.get("code") != 200)
                 			{
                 				return "EMR configuration missing. Please check App Config.";
                 			}
                 			else
                 			{
                 				baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 				bearerToken = tokenRec.get("token");
                 				emrBase = baseUrlRec.config_value;
                 				apiUrl = emrBase + "/api/remotecarepatientdevices/unassign";
                 				rcpdPayload = Map();
                 				rcpdPayload.put("device_id",invItem.device_unique_id);
                 				rcpdPayload.put("patient_id",kd.patient_ref_id1);
                 				rcpdPayload.put("unassigned_date",kd.offboarding_date1);
                 				headersMap = Map();
                 				headersMap.put("accept","*/*");
                 				headersMap.put("Content-Type","application/json");
                 				response = invokeurl
                 				[
                 					url :apiUrl
                 					type :POST
                 					body:rcpdPayload.toString()
                 					headers:headersMap
                 				];
                 				responseMap = response.toMap();
                 				if(responseMap.get("status") != 200 && responseMap.get("status") != 201)
                 				{
                 					return "Error in kit assignment";
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		return "Missing inventory hub";
                 	}
                 	return "Success";
                 }
				 string fn_kit_onboard(int distribution_id)
                 {
                 	kd = kit_issues[ID == distribution_id];
                 	kitRec = kit[ID = kd.kit];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.notes="Onboarding: Kit " + kitRec.ID + " onboarded on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + kitRec.notes;
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			tokenRec = thisapp.fn_getbearertoken();
                 			if(tokenRec.get("code") != 200)
                 			{
                 				return "EMR configuration missing. Please check App Config.";
                 			}
                 			else
                 			{
                 				baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 				bearerToken = tokenRec.get("token");
                 				emrBase = baseUrlRec.config_value;
                 				apiUrl = emrBase + "/api/remotecarepatientdevices/assign";
                 				rcpdPayload = Map();
                 				rcpdPayload.put("device_id",invItem.device_unique_id);
                 				rcpdPayload.put("patient_id",kd.patient_ref_id1);
                 				rcpdPayload.put("assigned_date",kd.onboarding_date1);
                 				headersMap = Map();
                 				headersMap.put("accept","*/*");
                 				headersMap.put("Content-Type","application/json");
                 				response = invokeurl
                 				[
                 					url :apiUrl
                 					type :POST
                 					body:rcpdPayload.toString()
                 					headers:headersMap
                 				];
                 				responseMap = response.toMap();
                 				if(responseMap.get("status") != 200 && responseMap.get("status") != 201)
                 				{
                 					return "Error in kit assignment";
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		return "Missing inventory hub";
                 	}
                 	return "Success";
                 }
				 string fn_kit_reassign(int distribution_id, date assign_date, date unassign_date, int reason)
                 {
                 	kd = kit_issues[ID == distribution_id];
                 	kitRec = kit[ID = kd.kit];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.notes="Offboarding: Kit " + kitRec.ID + " onboarded on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + kitRec.notes;
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			tokenRec = thisapp.fn_getbearertoken();
                 			if(tokenRec.get("code") != 200)
                 			{
                 				return "EMR configuration missing. Please check App Config.";
                 			}
                 			else
                 			{
                 				baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 				bearerToken = tokenRec.get("token");
                 				emrBase = baseUrlRec.config_value;
                 				apiUrl = emrBase + "/api/remotecarepatientdevices/reassign";
                 				rcpdPayload = Map();
                 				rcpdPayload.put("device_id",invItem.device_unique_id);
                 				rcpdPayload.put("patient_id",kd.patient_ref_id1);
                 				rcpdPayload.put("assigned_date",assign_date);
                 				rcpdPayload.put("unassigned_date",unassign_date);
                 				rcpdPayload.put("reason_id",reason);
                 				headersMap = Map();
                 				headersMap.put("accept","*/*");
                 				headersMap.put("Content-Type","application/json");
                 				response = invokeurl
                 				[
                 					url :apiUrl
                 					type :POST
                 					body:rcpdPayload.toString()
                 					headers:headersMap
                 				];
                 				responseMap = response.toMap();
                 				if(responseMap.get("status") != 200 && responseMap.get("status") != 201)
                 				{
                 					return "Error in kit assignment";
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		return "Missing inventory hub";
                 	}
                 	return "Success";
                 }
				 string fn_kit_reassing(int distribution_id, date assign_date, date unassign_date)
                 {
                 	return "";
                 }
				 void fn_setKitStatus(bigint kitID, string statusType)
                 {
                 	if(statusType == "INVENTORY")
                 	{
                 		kitStatus = "AVAILABLE";
                 		itemStatus = "IN KIT";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "ALLOCATED")
                 	{
                 		kitStatus = "ALLOCATED";
                 		itemStatus = "ALLOCATED";
                 		kitLoc = Location[location_name == "Patient"].ID;
                 	}
                 	else if(statusType == "STERLIZE")
                 	{
                 		kitStatus = "TO BE STERILIZED";
                 		itemStatus = "TO BE STERILIZED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "RETURN")
                 	{
                 		kitStatus = "RETURNED";
                 		itemStatus = "RETURNED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "OFFBOARD")
                 	{
                 		kitStatus = "OFFBOARDED";
                 		itemStatus = "OFFBOARDED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "LOST")
                 	{
                 		kitStatus = "LOST";
                 		itemStatus = "LOST";
                 		kitLoc = "";
                 	}
                 	else
                 	{
                 		return;
                 	}
                 	kitRec = kit[ID = kitID];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.kit_status=kitStatus;
                 		kitRec.notes=kitStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + kitRec.notes;
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			invItem.status=itemStatus;
                 		}
                 		bagRec = bags[ID == kitRec.bag1.ID];
                 		if(bagRec != null && bagRec.count() > 0)
                 		{
                 			bagRec.status=itemStatus;
                 			bagRec.notes=itemStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + bagRec.notes;
                 		}
                 		for each  kt in kitRec.Kit_Items
                 		{
                 			// ← iterate from the fetched record, not input
                 			if(kt.inventory_items != null)
                 			{
                 				invItem = inventory_items[ID == kt.inventory_items.ID && Peripheral_Type == kt.Peripheral_Type.ID];
                 				if(invItem.count() > 0)
                 				{
                 					invItem.status=itemStatus;
                 					invItem.notes=itemStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + invItem.notes;
                 				}
                 			}
                 		}
                 	}
                 }
			 }
		 }
		workflow
		{
		form
		{
			Hub_or_Peripheral_selecti as "Hub or Peripheral selection"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				field rules
				{
					actions  (device_category == "HUB")
					{
						hide Peripheral_Type;
						hide peripheral_model;
					}
					actions  (device_category == "PERIPHERAL")
					{
						hide asset_tag;
						hide active_sim_number;
						hide device_model1;
					}
					actions 
					{
						hide previous_active_sim,sim_change_reason,old_sim_next_status;
					}
				}

			}
			Peripheral_type as "Peripheral_type"
			{
				type =  form
				form = device_models

				record event = on add or edit

				field rules
				{
					actions  (device_category == "HUB")
					{
						hide peripheral_type1;
					}
				}

			}
			Auto_ID as "Auto_ID"
			{
				type =  form
				form = kit_issues

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											year_val = zoho.currentdate.toString("yyyy");
										month_val = zoho.currentdate.toString("MM");
										count_val = kit_issues.count() + 1;
										kit_number = "KDT-" + year_val + "-" + month_val + "-" + count_val.toString("000");
										input.provision_id = kit_number;
										input.distribution_status = "ALLOCATED";
										disable provision_id;
										disable distribution_status;
										hide kit_request_type1;
										disable patient_ref_id1;
										hide patient_ref_id1;
										hide onboarding_date1;
										hide replacement_date1;
										hide offboarding_date1;
										hide replacement_reason1;
						)
					}
				}

			}
			KIT_ID as "KIT_ID"
			{
				type =  form
				form = kit

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											/*year_val = zoho.currentdate.toString("yyyy");
														month_val = zoho.currentdate.toString("MM");
														count_val = kit[kit_code != ""].count() + 1;
														kit_number = "KIT-" + year_val + "-" + month_val + "-" + count_val.toString("000");
														input.kit_code = kit_number;*/
										input.kit_status = "AVAILABLE";
						)
					}
				}

			}
			Bag_ID as "Bag_ID"
			{
				type =  form
				form = bags

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.status = "IN STOCK";
										disable status;
						)
					}
				}

			}
			hub_sim_assignments_onsuc as "hub_sim_assignments_onsuccess"
			{
				type =  form
				form = hub_sim_assignments

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											simRec = sim_cards[ID == input.sim_card];
										if(simRec != null)
										{
											simRec.status="IN KIT";
										}
										hubRec = inventory_items[ID == input.hub_item];
										if(hubRec != null)
										{
											hubRec.active_sim_number=input.sim_card;
										}
						)
					}
				}

			}
			Change_SIM_onvalidate as "Change_SIM_onvalidate"
			{
				type =  form
				form = Change_SIM

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.sim_change_hub == null)
										{
											alert "Please select a hub.";
											cancel submit;
										}
										if(input.new_sim_card == null)
										{
											if(input.remove_sim == false)
											{
												alert "Please select a new SIM or select Remove SIM.";
												cancel submit;
											}
										}
										if(input.change_reason == null || input.change_reason.trim() == "")
										{
											alert "Please specify the reason for SIM change.";
											cancel submit;
										}
										hub = inventory_items[ID == input.sim_change_hub];
										if(hub == null || hub.device_category != "HUB")
										{
											alert "SIM can be changed only for HUB items.";
											cancel submit;
										}
										if(input.new_sim_card != null)
										{
											newSim = sim_cards[ID == input.new_sim_card];
											if(newSim == null)
											{
												alert "Selected SIM not found.";
												cancel submit;
											}
											if(newSim.status != "ACTIVE")
											{
												alert "Only ACTIVE SIM can be selected.";
												cancel submit;
											}
											activeForHub = hub_sim_assignments[hub_item == input.sim_change_hub];
											if(activeForHub != null && activeForHub.sim_card.ID == input.new_sim_card)
											{
												alert "This SIM is already assigned to the selected hub.";
												cancel submit;
											}
											activeElsewhereCount = hub_sim_assignments[sim_card == input.new_sim_card && hub_item != input.sim_change_hub].count();
											if(activeElsewhereCount > 0)
											{
												alert "This SIM is already assigned to another hub.";
												cancel submit;
											}
										}
						)
					}
				}

			}
			Change_SIM_onsuccess as "Change_SIM_onsuccess"
			{
				type =  form
				form = Change_SIM

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											activeForHub = hub_sim_assignments[hub_item == input.sim_change_hub];
										if(activeForHub.count() > 0)
										{
											if(input.current_sim != null)
											{
												oldSim = sim_cards[ID == activeForHub.sim_card];
												if(oldSim.count() > 0)
												{
													if(input.change_reason = "SIM Problem")
													{
														oldSim.status="RETIRED";
													}
													else
													{
														oldSim.status="ACTIVE";
													}
												}
											}
											if(input.new_sim_card == null)
											{
												if(input.remove_sim == true)
												{
													delete from hub_sim_assignments[hub_item == input.sim_change_hub];
												}
											}
											else
											{
												activeForHub.sim_card=input.new_sim_card;
												activeForHub.assigned_on=zoho.currenttime;
												activeForHub.assigned_by=zoho.loginuser;
												activeForHub.notes="Changed from Change SIM form. Reason: " + input.change_reason + if(input.change_notes != null && input.change_notes != ""," | Notes: " + input.change_notes,"");
											}
										}
										else
										{
											insert into hub_sim_assignments
											[
												hub_item=input.sim_change_hub
												sim_card=input.new_sim_card
												assigned_on=zoho.currenttime
												notes="Assigned from Change SIM form. Reason: " + input.change_reason + if(input.change_notes != null && input.change_notes != ""," | Notes: " + input.change_notes,"")
												assigned_by=zoho.loginuser
												Added_User=zoho.loginuser
											]
										}
										if(input.new_sim_card != null)
										{
											newSim = sim_cards[ID == input.new_sim_card];
											if(newSim.count() > 0)
											{
												newSim.status="IN HUB";
											}
										}
										hubRec = inventory_items[ID == input.sim_change_hub];
										if(hubRec.count() > 0)
										{
											hubRec.active_sim_number=input.new_sim_card;
										}
						)
					}
				}

			}
			get_oldsim as "get_oldsim"
			{
				type =  form
				form = Change_SIM

				record event = on add or edit

				on user input of sim_change_hub
				{
					actions 
					{
						custom deluge script
						(
											assignRec = hub_sim_assignments[hub_item == input.sim_change_hub];
										if(assignRec != null && assignRec.sim_card != null)
										{
											input.current_sim = assignRec.sim_card.sim_number;
										}
										else
										{
											input.current_sim = "";
										}
						)
					}
				}

			}
			validatesim as "validatesim"
			{
				type =  form
				form = hub_sim_assignments

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(hub_sim_assignments[hub_item == input.hub_item].sim_card != null)
										{
											alert "This SIM is already assigned to another hub.";
											cancel submit;
										}
						)
					}
				}

			}
			init_status as "init_status"
			{
				type =  form
				form = sim_cards

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.status = "NEW";
						)
					}
				}

			}
			Change_SIM_confirm_toggl as "Change_SIM_confirm_toggl"
			{
				type =  form
				form = Change_SIM

				record event = on add or edit

				field rules
				{
					actions  (new_sim_card is null)
					{
						show remove_sim;
					}
					actions  (new_sim_card is not null)
					{
						hide remove_sim;
					}
				}

			}
			peripheral_filter as "peripheral_filter"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				on user input of Peripheral_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.device_category == "PERIPHERAL")
										{
											clear peripheral_model;
											modelIds = List();
											for each  dm in device_models[device_category == "PERIPHERAL" && peripheral_type1 == input.Peripheral_Type]
											{
												modelIds.add(dm.ID);
											}
											input.peripheral_model:ui.add(modelIds);
										}
						)
					}
				}

			}
			itemValidationCheck as "itemValidationCheck"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.device_category == "HUB")
										{
											if(input.device_model1 == null)
											{
												alert "Select device model";
												cancel submit;
											}
										}
										if(input.device_category == "PERIPHERAL")
										{
											if(input.peripheral_model == null)
											{
												alert "Select peripheral model";
												cancel submit;
											}
										}
										if(input.previous_active_sim != null && input.active_sim_number != input.previous_active_sim)
										{
											if(input.sim_change_reason == null || input.sim_change_reason.trim() == "")
											{
												alert "Please provide SIM change reason.";
												cancel submit;
											}
											if(input.old_sim_next_status == null || input.old_sim_next_status == "")
											{
												alert "Please select old SIM status (ACTIVE or SUSPENDED).";
												cancel submit;
											}
										}
										if(input.device_category == "HUB" && input.active_sim_number != null)
										{
											simMappedElsewhere = hub_sim_assignments[sim_card == input.active_sim_number && hub_item != input.ID].count();
											if(simMappedElsewhere > 0)
											{
												alert "Selected SIM is already mapped to another hub.";
												cancel submit;
											}
										}
										if(input.status == "ALLOCATED")
										{
											alert "Use kit distribution option to issue hub or peripherals to patient.";
											cancel submit;
										}
						)
					}
				}

			}
			loadModelFilter as "loadModelFilter"
			{
				type =  form
				form = inventory_items

				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											perModel = input.peripheral_model;
										input.previous_active_sim = input.active_sim_number;
										hide sim_change_reason;
										hide old_sim_next_status;
										if(input.device_category == "PERIPHERAL")
										{
											clear peripheral_model;
											modelIds = List();
											for each  dm in device_models[device_category == "PERIPHERAL" && peripheral_type1 == input.Peripheral_Type]
											{
												modelIds.add(dm.ID);
											}
											input.peripheral_model:ui.add(modelIds);
										}
										if(perModel != null)
										{
											input.peripheral_model = perModel;
										}
						)
					}
				}

			}
			initValues as "initValues"
			{
				type =  form
				form = inventory_items

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.status = "IN STOCK";
										disable status;
						)
					}
				}

			}
			locSet as "locSet"
			{
				type =  form
				form = kit

				record event = on add or edit

				on user input of kit_status
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_status = "ALLOCATED")
										{
											input.Location = Location[location_name == "Patient"].ID;
										}
						)
					}
				}

			}
			validateItems as "validateItems"
			{
				type =  form
				form = kit

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_code == null || input.kit_code.trim().isEmpty())
										{
											alert "Kit code should not be empty";
											cancel submit;
										}
										if(input.kit_status == "ALLOCATED")
										{
											alert "Kit issue should be done thorugh Kit Distribution option";
											cancel submit;
										}
										if(input.kit_status == "AVAILABLE")
										{
											if(input.bag1 == null)
											{
												alert "Please select a Bag before proceeding.";
												cancel submit;
											}
											if(input.hub_item1 == null)
											{
												alert "Please select a Hub before proceeding.";
												cancel submit;
											}
										}
										if(input.hub_item1 != null)
										{
											otherHubCount = 0;
											if(input.ID != null)
											{
												otherHubCount = kit[hub_item1 == input.hub_item1 && ID != input.ID].count();
											}
											else
											{
												otherHubCount = kit[hub_item1 == input.hub_item1].count();
											}
											if(otherHubCount > 0)
											{
												alert "Selected hub is already assigned in another kit.";
												cancel submit;
											}
										}
										selectedItemIds = List();
										kitItemAvailable = false;
										for each  kiRow in input.Kit_Items
										{
											if(kiRow.inventory_items != null)
											{
												if(selectedItemIds.contains(kiRow.inventory_items))
												{
													alert "Same inventory item cannot be added multiple times in one kit.";
													cancel submit;
												}
												selectedItemIds.add(kiRow.inventory_items);
												otherKitCount = 0;
												if(input.ID != null)
												{
													otherKitCount = kit[Kit_Items.inventory_items == kiRow.inventory_items && ID != input.ID].count();
												}
												else
												{
													otherKitCount = kit[Kit_Items.inventory_items == kiRow.inventory_items].count();
												}
												if(otherKitCount > 0)
												{
													alert "Inventory item " + kiRow.inventory_items.serial_number + " is already assigned in another kit.";
													cancel submit;
												}
												kitItemAvailable = true;
											}
										}
										if(!kitItemAvailable)
										{
											alert "Atlease one inventory item should be selected";
											cancel submit;
										}
										if(input.Location.location_name == "PATIENT")
										{
											alert "Location shoulid not be Patient for new kit, use Kit disctribution to issue to patient";
											cancel submit;
										}
						)
					}
				}

			}
			setStatus as "setStatus"
			{
				type =  form
				form = kit

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_status == "ALLOCATED")
										{
											// Update Bag status
											if(input.bag1 != null)
											{
												// replace `bag` with your bag lookup field API name
												bagRec = bags[ID == input.bag1];
												if(bagRec.count() > 0)
												{
													bagRec.status="ALLOCATED";
												}
											}
											// Update Hub status
											if(input.hub_item1 != null)
											{
												// replace `hub_item1` with your hub lookup field API name
												hubRec = inventory_items[ID == input.hub_item1 && device_category == "HUB"];
												if(hubRec.count() > 0)
												{
													hubRec.status="ALLOCATED";
												}
											}
										}
										if(input.kit_status == "AVAILABLE")
										{
											// Update Bag status
											if(input.bag1 != null)
											{
												// replace `bag` with your bag lookup field API name
												bagRec = bags[ID == input.bag1];
												if(bagRec.count() > 0)
												{
													bagRec.status="IN KIT";
												}
											}
											// Update Hub status
											if(input.hub_item1 != null)
											{
												// replace `hub_item1` with your hub lookup field API name
												hubRec = inventory_items[ID == input.hub_item1 && device_category == "HUB"];
												if(hubRec.count() > 0)
												{
													hubRec.status="IN KIT";
												}
											}
										}
										// Remove Kit_Items rows where inventory_items is null
										// Use input.Kit_Items (submitted form data) — works for both new and existing kits
										/*
																		col=Collection();
																		for each i in input.<SubForm_Field_Link_Name>
																		{
																		roww=<Form_Link_Name>.<SubForm_Field_Link_Name> ();
																		if(i.<inventory_items_Field_Link_Name>!=null)
																		{
																		roww.<Field_Link_Name1>=i.<Field_Link_Name1>;
																		roww.<Field_Link_Name2>=i.<Field_Link_Name2>;
																		}
																		col.insert(roww);
																		}
																		input.<SubForm_Field_Link_Name> .clear();
																		input.<SubForm_Field_Link_Name> .insert(col);
																		*/
										col = Collection();
										for each  i in input.Kit_Items
										{
											kiRow = kit.Kit_Items();
											if(i.inventory_items != null)
											{
												kiRow.Peripheral_Type=i.Peripheral_Type;
												kiRow.inventory_items=i.inventory_items;
												invItem = inventory_items[ID == i.inventory_items.ID];
												invItem.status=hubRec.status;
												col.insert(kiRow);
											}
										}
										input.Kit_Items.clear();
										input.Kit_Items.insert(col);
						)
					}
				}

			}
			setStatusAndSIM as "setStatusAndSIM"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.previous_active_sim != null && input.active_sim_number != input.previous_active_sim)
										{
											oldSIM = sim_cards[ID == input.previous_active_sim];
											if(oldSIM != null && input.old_sim_next_status == "ACTIVE" || input.old_sim_next_status == "SUSPENDED")
											{
												oldSIM.status=input.old_sim_next_status;
											}
										}
										if(input.active_sim_number != null)
										{
											activeSIM = sim_cards[ID == input.active_sim_number];
											if(activeSIM != null)
											{
												activeSIM.status="IN HUB";
											}
										}
										if(input.device_category == "HUB")
										{
											existingAssignCount = hub_sim_assignments[hub_item == input.ID].count();
											existingAssign = null;
											if(existingAssignCount > 0)
											{
												existingAssign = hub_sim_assignments[hub_item == input.ID];
											}
											if(input.active_sim_number == null)
											{
												if(existingAssign != null)
												{
													delete from hub_sim_assignments[ID == existingAssign.ID];
												}
											}
											else
											{
												if(existingAssign != null)
												{
													existingAssign.sim_card=input.active_sim_number;
													existingAssign.assigned_on=zoho.currenttime;
													existingAssign.assigned_by=zoho.loginuser;
													existingAssign.notes="Synced from Inventory Items form";
												}
												else
												{
													insert into hub_sim_assignments
													[
														hub_item=input.ID
														sim_card=input.active_sim_number
														assigned_on=zoho.currenttime
														notes="Synced from Inventory Items form"
														assigned_by=zoho.loginuser
														Added_User=zoho.loginuser
													]
												}
											}
										}
										input.previous_active_sim = input.active_sim_number;
						)
					}
				}

			}
