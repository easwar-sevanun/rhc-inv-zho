			Kit_Replace_LoadKit as "Kit_Replace_LoadKit"
			{
				type =  form
				form = Kit_Replace

				record event = on add or edit

				on user input of kit_ref
				{
					actions 
					{
						custom deluge script
						(
											// Reset all fields when kit changes
										input.old_bag = null;
										input.new_bag = null;
										input.old_hub = null;
										input.new_hub = null;
										hide bag_condition;
										hide bag_new_status;
										hide hub_condition;
										hide hub_new_status;
										if(input.kit_ref != null)
										{
											kt = kit[ID == input.kit_ref];
											if(kt.count() > 0)
											{
												// Pre-fill current bag and hub from kit record
												input.old_bag = kt.bag1;
												input.new_bag = kt.bag1;
												input.old_hub = kt.hub_item1;
												input.new_hub = kt.hub_item1;
												// Show condition/status fields for bag if kit has a bag
												if(kt.bag1 != null)
												{
													show bag_condition;
													show bag_new_status;
												}
												// Show condition/status fields for hub if kit has a hub
												if(kt.hub_item1 != null)
												{
													show hub_condition;
													show hub_new_status;
												}
											}
										}
						)
