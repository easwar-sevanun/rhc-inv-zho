		 functions
		 {
			 Deluge
			 {
				 string errMsg(string msg)
                 {
                 	return "::" + zoho.currenttime + "::" + msg;
                 }
				 map fn_assign_or_replace_sim(string hubScan, string simScan, date activatedOn, string reason, string notes)
                 {
                 	res = Map();
                 	res.put("success",true);
                 	res.put("message","");
                 	// resolve hub
                 	hub = inventory_items[internal_barcode == hubScan || serial_number == hubScan];
                 	if(hub == null || hub.device_category != "HUB")
                 	{
                 		res.put("success",false);
                 		res.put("message","Hub not found or not a HUB.");
                 		return res;
                 	}
                 	// resolve SIM
                 	sim = sim_cards[sim_number == simScan];
                 	if(sim == null)
                 	{
                 		sim = sim_cards[iccid == simScan];
                 	}
                 	if(sim == null)
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM not found.");
                 		return res;
                 	}
                 	if(!(sim.status == "AVAILABLE" || sim.status == "ACTIVE"))
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM status must be AVAILABLE or ACTIVE.");
                 		return res;
                 	}
                 	// block SIM active elsewhere
                 	other = hub_sim_assignments[sim_card == sim.ID];
                 	if(other != null && other.hub_item.ID != hub.ID)
                 	{
                 		res.put("success",false);
                 		res.put("message","SIM already assigned to another hub.");
                 		return res;
                 	}
                 	// close existing SIM on hub
                 	existing = hub_sim_assignments[hub_item == hub.ID];
                 	if(existing != null)
                 	{
                 		oldSim = sim_cards[ID == existing.sim_card];
                 		if(oldSim != null)
                 		{
                 			oldSim.status="AVAILABLE";
                 		}
                 		delete from hub_sim_assignments[ID == existing.ID];
                 	}
                 	if(reason != null && reason != "")
                 	{
                 		cr = reason;
                 	}
                 	else
                 	{
                 		cr = "INITIAL";
                 	}
                 	// create new assignment
                 	insert into hub_sim_assignments
                 	[
                 		hub_item=hub.ID
                 		sim_card=sim.ID
                 		assigned_on=zoho.currenttime
                 		notes=notes
                 		assigned_by=zoho.loginuser
                 		Added_User=zoho.loginuser
                 	]
                 	// update SIM master
                 	simRec = sim_cards[ID == sim.ID];
                 	if(simRec != null)
                 	{
                 		simRec.status="IN KIT";
                 		if(sim.activation_date == null && activatedOn != null)
                 		{
                 			simRec.activation_date=activatedOn;
                 		}
                 	}
                 	//sim_cards[ID == sim.ID].status = "ACTIVE";
                 	// update hub cache
                 	hubRec = inventory_items[ID == hub.ID];
                 	if(hubRec != null)
                 	{
                 		hubRec.active_sim_number=sim.ID;
                 	}
                 	res.put("success",true);
                 	res.put("message","SIM assigned / replaced successfully.");
                 	return res;
                 }
				 map fn_findpatiendeviceid(string patient_ref_id)
                 {
                 	result = Map();
                 	result.put("code",500);
                 	result.put("device_record_id",0);
                 	result.put("message","Unknown error");
                 	getUrl = "/api/remotecarepatientdevices?query=patient_id%3D" + patient_ref_id + "&status=active";
                 	getMap = thisapp.fn_invokeapi(getUrl,"GET",null);
                 	getStatus = 0;
                 	deviceRecordId = 0;
                 	if(getMap != null)
                 	{
                 		getStatus = getMap.get("responseCode");
                 		if(getStatus == 200 || getStatus == 201)
                 		{
                 			getResponse = getMap.get("responseText").toMap();
                 			getData = getResponse.get("data");
                 			if(getData != null && getData.size() > 0)
                 			{
                 				firstRow = getData.get(0).toMap();
                 				deviceRecordId = firstRow.get("device_id");
                 				if(deviceRecordId != null)
                 				{
                 					result.put("code",getStatus);
                 					result.put("device_record_id",deviceRecordId);
                 					result.put("message","Success");
                 					result.put("data",getData);
                 					return result;
                 				}
                 				else
                 				{
                 					result.put("code",getStatus);
                 					result.put("device_record_id",deviceRecordId);
                 					result.put("message",getMap.get("responseText").toMap().get("detail"));
                 				}
                 			}
                 			else
                 			{
                 				result.put("code",getStatus);
                 				result.put("device_record_id",deviceRecordId);
                 				result.put("message",getMap.get("responseText").toMap().get("detail"));
                 			}
                 		}
                 		else
                 		{
                 			result.put("code",getStatus);
                 			result.put("device_record_id",deviceRecordId);
                 			result.put("message",getMap.get("responseText").toMap().get("detail"));
                 			return result;
                 		}
                 	}
                 	return result;
                 }
				 string fn_generate_code(string prefix, int seq)
                 {
                 	return prefix + "-" + "000000".subString(0,6 - seq.toString().length()) + seq;
                 }
				 map fn_getapitoken()
                 {
                 	baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 	retmsg = Map();
                 	retmsg.put("code",200);
                 	retmsg.put("msg","Success");
                 	if(baseUrlRec.count() == 0)
                 	{
                 		retmsg.put("code",1);
                 		retmsg.put("msg","EMR configuration missing. Please check App Config.");
                 		return retmsg;
                 	}
                 	else
                 	{
                 		emrBase = baseUrlRec.config_value;
                 		refreshTokenUpdate = App_Config[config_key == "EMR_REFRESH_TOKEN"];
                 		loginPayload = Map();
                 		if(refreshTokenUpdate == null || refreshTokenUpdate.count() == 0 || refreshTokenUpdate.config_value == null || refreshTokenUpdate.config_value.trim() == "")
                 		{
                 			apiUrl = emrBase + "/api/auth/login";
                 		}
                 		else
                 		{
                 			loginPayload.put("refreshToken",refreshTokenUpdate.config_value);
                 			apiUrl = emrBase + "/api/auth/refreshlogin";
                 		}
                 		loginPayload.put("allowRemoteCare",true);
                 		loginPayload.put("password",App_Config[config_key == "EMR_PASSWORD"].config_value);
                 		loginPayload.put("roleType","GENERAL");
                 		loginPayload.put("username",App_Config[config_key == "EMR_USERNAME"].config_value);
                 		headersMap = Map();
                 		headersMap.put("accept","*/*");
                 		headersMap.put("Content-Type","application/json");
                 		response = invokeurl
                 		[
                 			url :apiUrl
                 			type :POST
                 			body:loginPayload.toString()
                 			headers:headersMap
                 			detailed:true
                 		];
                 		responseMap = response.toMap();
                 		if(responseMap.get("responseCode") == 200 || responseMap.get("responseCode") == 201)
                 		{
                 			responseMap = responseMap.get("responseText");
                 			bearerToken = responseMap.get("token");
                 			if(bearerToken == null || bearerToken.size() == 0)
                 			{
                 				retmsg.put("code",1);
                 				retmsg.put("msg","Login failed");
                 				return retmsg;
                 			}
                 			tokenUpdate = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 			tokenUpdate.config_value=bearerToken;
                 			refreshToken = responseMap.get("refreshToken");
                 			refreshTokenUpdate = App_Config[config_key == "EMR_REFRESH_TOKEN"];
                 			if(refreshToken == null || refreshToken.size() == 0)
                 			{
                 				retmsg.put("code",1);
                 				retmsg.put("msg","Login failed");
                 				return retmsg;
                 			}
                 			refreshTokenUpdate.config_value=refreshToken;
                 		}
                 		else
                 		{
                 			retmsg.put("code",responseMap.get("responseCode"));
                 			retmsg.put("msg",responseMap.get("responseText"));
                 			retmsg.put("addmsg","|" + apiUrl + "|" + refreshTokenUpdate.config_value);
                 			return retmsg;
                 		}
                 	}
                 	return retmsg;
                 }
				 map fn_getbearertoken()
                 {
                 	tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 	if(tokenRec == null || tokenRec.count() == 0)
                 	{
                 		rec = insert into App_Config
                 		[
                 			config_key="EMR_BEARER_TOKEN"
                 			config_value=""
                 			Added_User=zoho.loginuser
                 		];
                 	}
                 	tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 	retmsg = Map();
                 	retmsg.put("code",200);
                 	retmsg.put("msg","Success");
                 	if(tokenRec == null || tokenRec.count() == 0 || tokenRec.config_value == "" || tokenRec.config_value == null)
                 	{
                 		retstatus = thisapp.fn_getapitoken();
                 		if(retstatus.get("msg") == "Success")
                 		{
                 			tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
                 			retmsg.put("token",tokenRec.config_value);
                 		}
                 		else
                 		{
                 			retmsg.put("code",1);
                 			retmsg.put("msg",retstatus.get("msg"));
                 		}
                 	}
                 	else
                 	{
                 		retmsg.put("token",tokenRec.config_value);
                 	}
                 	return retmsg;
                 }
				 map fn_getdeviceid(int invItemId)
                 {
                 	result = Map();
                 	result.put("code",500);
                 	result.put("device_record_id",0);
                 	result.put("message","Unknown error");
                 	invItem = inventory_items[ID == invItemId];
                 	if(invItem == null || invItem.count() <= 0)
                 	{
                 		result.put("message","Missing inventory hub");
                 		return result;
                 	}
                 	assetTag = ifnull(invItem.asset_tag,"").trim();
                 	if(assetTag == "")
                 	{
                 		result.put("code",400);
                 		result.put("message","Missing asset tag");
                 		return result;
                 	}
                 	modelName = "";
                 	if(invItem.device_model1 != null)
                 	{
                 		dmRec = device_models[ID == invItem.device_model1];
                 		if(dmRec != null && dmRec.count() > 0)
                 		{
                 			modelName = ifnull(dmRec.model_name,"").trim();
                 		}
                 	}
                 	vendor = "";
                 	createDeviceUuid = "";
                 	if(modelName == "OMNY M2")
                 	{
                 		vendor = "Yantrr";
                 		createDeviceUuid = ifnull(invItem.device_unique_id,"").trim();
                 	}
                 	else if(modelName == "RemSync")
                 	{
                 		vendor = "Silicon";
                 		createDeviceUuid = ifnull(invItem.device_unique_id,"").trim();
                 	}
                 	else
                 	{
                 		result.put("code",400);
                 		result.put("message","Unknown device model mapping: " + modelName);
                 		return result;
                 	}
                 	if(createDeviceUuid == "")
                 	{
                 		result.put("code",400);
                 		result.put("message","Missing device unique id");
                 		return result;
                 	}
                 	apiUrl = "/api/remotecaredevices?query=status=unassigned&asset_tag_id=" + assetTag + "&page=1&size=100";
                 	getMap = thisapp.fn_invokeapi(apiUrl,"GET",null);
                 	if(getMap != null)
                 	{
                 		getStatus = ifnull(getMap.get("status"),0);
                 		getData = getMap.get("data");
                 		if(getStatus == 200 || getData != null)
                 		{
                 			if(getData != null && getData.size() > 0)
                 			{
                 				firstRow = getData.get(0);
                 				deviceRecordId = firstRow.get("id");
                 				if(deviceRecordId != null)
                 				{
                 					result.put("code",200);
                 					result.put("device_record_id",deviceRecordId);
                 					result.put("message","Success");
                 					result.put("errMessage",getData);
                 					result.put("asset_tag_id",assetTag);
                 					return result;
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		result.put("code",200);
                 		result.put("device_record_id",deviceRecordId);
                 		result.put("message","Error");
                 		result.put("errMessage",getData);
                 		return result;
                 	}
                 	errMsg = ifnull(getData.get("message"),"");
                 	if(errMsg == "")
                 	{
                 		errMsg = "Unable to resolve RemoteCare device record for asset tag " + assetTag + " (lookup status: " + getStatus + ")";
                 	}
                 	result.put("code",500);
                 	result.put("message",errMsg);
                 	return result;
                 }
				 map fn_hub_reassign(int newHubItem, string patientRefId, date assign_date, date unassign_date, int reason)
                 {
                 	notes = "Offboarding: Kit " + newHubItem + " onboarded on " + zoho.currentdate.toString("dd-MMM-yyyy");
                 	invItem = inventory_items[ID == newHubItem];
                 	ret = Map();
                 	if(invItem != null && invItem.count() > 0)
                 	{
                 		resolveRec = thisapp.fn_resolve_remotecare_device_record_id(newHubItem);
                 		if(resolveRec.get("code") != 200 && resolveRec.get("code") != 201)
                 		{
                 			ret.put("code",500);
                 			ret.put("message",resolveRec.get("message"));
                 			return ret;
                 		}
                 		else
                 		{
                 			deviceRecordId = resolveRec.get("device_record_id");
                 			if(deviceRecordId == null || deviceRecordId.toNumber() == 0)
                 			{
                 				ret.put("code",500);
                 				ret.put("message",thisapp.errMsg("Unable to resolve RemoteCare device record id"));
                 				return ret;
                 			}
                 			rcpdPayload = Map();
                 			rcpdPayload.put("new_device_id",deviceRecordId);
                 			rcpdPayload.put("patient_id",patientRefId);
                 			rcpdPayload.put("assigned_date",assign_date.toString("yyyy-MM-dd'T'HH:mm:ssZ"));
                 			rcpdPayload.put("unassigned_date",unassign_date.toString("yyyy-MM-dd'T'HH:mm:ssZ"));
                 			rcpdPayload.put("reason_id",reason);
                 			apiUrl = "/api/remotecarepatientdevices/reassign";
                 			responseMap = thisapp.fn_invokeapi(apiUrl,"POST",rcpdPayload);
                 			if(responseMap != null)
                 			{
                 				postStatus = responseMap.get("responseCode");
                 				if(postStatus == 200 || postStatus == 201)
                 				{
                 					postData = responseMap.get("responseText");
                 					postId = null;
                 					if(postData != null)
                 					{
                 						postId = postData.get("device_id");
                 						if(postId == null)
                 						{
                 							ret.put("code",500);
                 							ret.put("message",thisapp.errMsg("Error setting up device"));
                 							return ret;
                 						}
                 						ret.put("device_record_id",postId);
                 					}
                 					else
                 					{
                 						ret.put("code",500);
                 						ret.put("message",thisapp.errMsg("Error setting up device"));
                 						return ret;
                 					}
                 				}
                 				else
                 				{
                 					ret.put("code",500);
                 					ret.put("message",thisapp.errMsg("Error in kit assignment" + " | Date:" + assign_date + " ResponseCode:" + postStatus + " Error Detail:" + responseMap.get("responseText").toMap().get("detail")));
                 					return ret;
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		ret.put("code",500);
                 		ret.put("message",thisapp.errMsg("Hub not found"));
                 		return ret;
                 	}
                 	ret.put("code",200);
                 	ret.put("message","Hub " + invItem.serial_number + " Onboarded successfully");
                 	return ret;
                 }
				 map fn_invokeapi(string apiUrl, string requesttype, map bodymappayload)
                 {
                 	headersMap = Map();
                 	headersMap.put("accept","*/*");
                 	headersMap.put("Content-Type","application/json");
                 	tokenRec = thisapp.fn_getbearertoken();
                 	bearerToken = tokenRec.get("token");
                 	baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
                 	emrBase = baseUrlRec.config_value;
                 	if(emrBase == null || emrBase.trim() == "")
                 	{
                 		result = Map();
                 		result.put("responseCode",0);
                 		result.put("message","EMR base URL missing. Please check App Config.");
                 		return result;
                 	}
                 	if(bearerToken != null && bearerToken.trim() != "")
                 	{
                 		headersMap.put("Authorization","Bearer " + bearerToken);
                 	}
                 	else
                 	{
                 		result = Map();
                 		result.put("responseCode",0);
                 		result.put("message","bearerToken missing. Please check App Config.");
                 		return result;
                 	}
                 	responseMap = null;
                 	if(requesttype == "GET")
                 	{
                 		responseMap = invokeurl
                 		[
                 			url :emrBase + apiUrl
                 			type :GET
                 			headers:headersMap
                 			detailed:true
                 		];
                 		responseMap = responseMap.toMap();
                 		getStatus = 0;
                 		if(responseMap != null)
                 		{
                 			getStatus = responseMap.get("responseCode");
                 			if(getStatus == 401 || getStatus == 403)
                 			{
                 				ret = thisapp.fn_getapitoken();
                 				if(ret.get("code") == 200)
                 				{
                 					tokenRec = thisapp.fn_getbearertoken();
                 					bearerToken = tokenRec.get("token");
                 					if(bearerToken != null && bearerToken.trim() != "")
                 					{
                 						headersMap.put("Authorization","Bearer " + bearerToken);
                 					}
                 					else
                 					{
                 						result = Map();
                 						result.put("responseCode",0);
                 						result.put("message","bearerToken missing. Please check App Config.");
                 						return result;
                 					}
                 					responseMap = invokeurl
                 					[
                 						url :emrBase + apiUrl
                 						type :GET
                 						headers:headersMap
                 						detailed:true
                 					];
                 					responseMap = responseMap.toMap();
                 				}
                 				else
                 				{
                 					result = Map();
                 					result.put("responseCode",0);
                 					result.put("message","Error getting api token");
                 					return result;
                 				}
                 			}
                 		}
                 	}
                 	else if(requesttype == "POST")
                 	{
                 		responseMap = invokeurl
                 		[
                 			url :emrBase + apiUrl
                 			type :POST
                 			body:bodymappayload.toString()
                 			headers:headersMap
                 			detailed:true
                 		];
                 		postStatus = 0;
                 		responseMap = responseMap.toMap();
                 		if(responseMap != null)
                 		{
                 			postStatus = responseMap.get("responseCode");
                 			if(postStatus == 401 || postStatus == 403)
                 			{
                 				ret = thisapp.fn_getapitoken();
                 				if(ret.get("code") == 200)
                 				{
                 					tokenRec = thisapp.fn_getbearertoken();
                 					bearerToken = tokenRec.get("token");
                 					if(bearerToken != null && bearerToken.trim() != "")
                 					{
                 						headersMap.put("Authorization","Bearer " + bearerToken);
                 					}
                 					else
                 					{
                 						result = Map();
                 						result.put("responseCode",0);
                 						result.put("message","bearerToken missing. Please check App Config.");
                 						return result;
                 					}
                 					responseMap = invokeurl
                 					[
                 						url :emrBase + apiUrl
                 						type :POST
                 						body:bodymappayload.toString()
                 						headers:headersMap
                 						detailed:true
                 					];
                 					responseMap = responseMap.toMap();
                 				}
                 				else
                 				{
                 					result = Map();
                 					result.put("responseCode",0);
                 					result.put("message","Error getting api token");
                 					return result;
                 				}
                 			}
                 		}
                 	}
                 	else if(requesttype == "PUT")
                 	{
                 		responseMap = invokeurl
                 		[
                 			url :emrBase + apiUrl
                 			type :PUT
                 			body:bodymappayload.toString()
                 			headers:headersMap
                 			detailed:true
                 		];
                 		postStatus = 0;
                 		responseMap = responseMap.toMap();
                 		if(responseMap != null)
                 		{
                 			postStatus = responseMap.get("responseCode");
                 			if(postStatus == 401 || postStatus == 403)
                 			{
                 				ret = thisapp.fn_getapitoken();
                 				if(ret.get("code") == 200)
                 				{
                 					tokenRec = thisapp.fn_getbearertoken();
                 					bearerToken = tokenRec.get("token");
                 					if(bearerToken != null && bearerToken.trim() != "")
                 					{
                 						headersMap.put("Authorization","Bearer " + bearerToken);
                 					}
                 					else
                 					{
                 						result = Map();
                 						result.put("responseCode",0);
                 						result.put("message","bearerToken missing. Please check App Config.");
                 						return result;
                 					}
                 					responseMap = invokeurl
                 					[
                 						url :emrBase + apiUrl
                 						type :PUT
                 						body:bodymappayload.toString()
                 						headers:headersMap
                 						detailed:true
                 					];
                 					responseMap = responseMap.toMap();
                 				}
                 				else
                 				{
                 					result = Map();
                 					result.put("responseCode",0);
                 					result.put("message","Error getting api token");
                 					return result;
                 				}
                 			}
                 		}
                 	}
                 	return responseMap;
                 }
				 string fn_kit_offboard(int distribution_id, int reason)
                 {
                 	kd = kit_issues[ID == distribution_id];
                 	kitRec = kit[ID = kd.kit];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.notes="Offboarding: Kit " + kitRec.ID + " offboarding device ref " + kd.device_ref_id1.toLong() + " for patient ref " + kd.patient_ref_id1 + " offboarded on " + zoho.currentdate.toString("dd-MMM-yyyy");
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			apiUrl = "/api/remotecarepatientdevices/unassign";
                 			deviceRecordId = kd.device_ref_id1.toLong();
                 			if(deviceRecordId == null || deviceRecordId == 0)
                 			{
                 				resolveRec = thisapp.fn_getdeviceid(invItem.ID);
                 				if(resolveRec.get("code") != 200)
                 				{
                 					return thisapp.errMsg("Unable to resolve RemoteCare device record id");
                 				}
                 				deviceRecordId = resolveRec.get("device_record_id");
                 				kd.device_ref_id1=deviceRecordId;
                 			}
                 			rcpdPayload = Map();
                 			rcpdPayload.put("device_id",deviceRecordId);
                 			rcpdPayload.put("patient_id",kd.patient_ref_id1);
                 			rcpdPayload.put("unassigned_date",kd.offboarding_date1.toString("yyyy-MM-dd'T'HH:mm:ssZ"));
                 			rcpdPayload.put("reason_id",reason);
                 			responseMap = thisapp.fn_invokeapi(apiUrl,"POST",rcpdPayload);
                 			if(responseMap != null)
                 			{
                 				postStatus = responseMap.get("responseCode");
                 				if(postStatus == 200 || postStatus == 201)
                 				{
                 					postData = responseMap.get("responseText");
                 					if(postData == null)
                 					{
                 						return thisapp.errMsg("Error in kit offboarding - Pat:" + kd.patient_ref_id1 + " - Dev:" + deviceRecordId + "- | Date:" + kd.offboarding_date1 + "Respone Map:" + responseMap);
                 					}
                 				}
                 				else
                 				{
                 					return thisapp.errMsg("Error in kit offboarding - Pat:" + kd.patient_ref_id1 + " - Dev:" + deviceRecordId + "- | Date:" + kd.offboarding_date1 + "Respone Map:" + responseMap);
                 				}
                 			}
                 			else
                 			{
                 				return thisapp.errMsg("Error in kit offboarding - Pat:" + kd.patient_ref_id1 + " - Dev:" + deviceRecordId + "- | Date:" + kd.offboarding_date1 + "Respone Map:" + responseMap);
                 			}
                 		}
                 	}
                 	else
                 	{
                 		return thisapp.errMsg("Missing inventory hub");
                 	}
                 	kitRec.notes="Offboarding: Kit " + kitRec.ID + " offboarded on " + kd.offboarding_date1;
                 	kd.notes="Offboarding: Kit " + kitRec.ID + " offboarded on " + kd.offboarding_date1;
                 	return "Success";
                 }
				 string fn_kit_onboard(int distribution_id)
                 {
                 	//string fn_kit_onboard(int distribution_id, date onboarddate)
                 	kd = kit_issues[ID == distribution_id];
                 	kitRec = kit[ID = kd.kit];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			devfin = thisapp.fn_findpatiendeviceid(kd.patient_ref_id1);
                 			if(devfin != null && devfin.size() > 0)
                 			{
                 				if(devfin.get("code") == 200 || devfin.get("code") == 201)
                 				{
                 					deviceRecordId = devfin.get("device_record_id");
                 					if(deviceRecordId != null && deviceRecordId > 0)
                 					{
                 						kd.device_ref_id1=deviceRecordId;
                 						return "Success";
                 					}
                 					else
                 					{
                 						return thisapp.errMsg(devfin.get("responseText").toMap().get("detail"));
                 					}
                 				}
                 				else
                 				{
                 					return thisapp.errMsg(devfin.get("responseText").toMap().get("detail"));
                 				}
                 			}
                 			resolveRec = thisapp.fn_resolve_remotecare_device_record_id(invItem.ID);
                 			if(resolveRec.get("code") != 200)
                 			{
                 				return thisapp.errMsg(resolveRec.get("message"));
                 			}
                 			deviceRecordId = resolveRec.get("device_record_id");
                 			if(deviceRecordId == null || deviceRecordId == 0)
                 			{
                 				if(resolveRec.get("message").toString().lower().contains("is already in assigned state"))
                 				{
                 					return thisapp.errMsg("Device: " + invItem.serial_number + "already assigned, check with support and offboard before assigning.");
                 				}
                 			}
                 			kd.device_ref_id1=deviceRecordId;
                 			//kd.onboarding_date1=onboarddate;
                 			rcpdPayload = Map();
                 			rcpdPayload.put("device_id",deviceRecordId);
                 			rcpdPayload.put("patient_id",kd.patient_ref_id1);
                 			rcpdPayload.put("assigned_date",kd.onboarding_date1.toString("yyyy-MM-dd'T'HH:mm:ssZ"));
                 			apiUrl = "/api/remotecarepatientdevices/assign";
                 			responseMap = thisapp.fn_invokeapi(apiUrl,"POST",rcpdPayload);
                 			if(responseMap != null)
                 			{
                 				postStatus = responseMap.get("responseCode");
                 				if(postStatus == 200 || postStatus == 201)
                 				{
                 					postData = responseMap.get("responseText");
                 					postId = null;
                 					if(postData != null)
                 					{
                 						postId = postData.get("id");
                 						if(postId == null)
                 						{
                 							return thisapp.errMsg("Error setting up device");
                 						}
                 					}
                 					else
                 					{
                 						return thisapp.errMsg("Error setting up device");
                 					}
                 				}
                 				else
                 				{
                 					return thisapp.errMsg("Error in kit assignment" + " | Date:" + kd.onboarding_date1 + " ResponseCode:" + postStatus + " Error Detail:" + responseMap.get("responseText").toMap().get("detail"));
                 				}
                 			}
                 		}
                 	}
                 	else
                 	{
                 		return thisapp.errMsg("Missing inventory hub");
                 	}
                 	kitRec.notes="Onboarding: Kit " + kitRec.ID + " onboarded on " + kd.onboarding_date1;
                 	kd.notes="Onboarding: Kit " + kitRec.ID + " onboarded on " + kd.onboarding_date1;
                 	return "Success";
                 }
				 map fn_resolve_remotecare_device_record_id(int invItemId)
                 {
                 	result = Map();
                 	result.put("code",500);
                 	result.put("device_record_id",0);
                 	result.put("message","Unknown error");
                 	invItem = inventory_items[ID == invItemId];
                 	if(invItem == null || invItem.count() <= 0)
                 	{
                 		result.put("message","Missing inventory hub");
                 		return result;
                 	}
                 	assetTag = ifnull(invItem.asset_tag,"").trim();
                 	if(assetTag == "")
                 	{
                 		result.put("code",400);
                 		result.put("message","Missing asset tag");
                 		return result;
                 	}
                 	modelName = "";
                 	if(invItem.device_model1 != null)
                 	{
                 		dmRec = device_models[ID == invItem.device_model1];
                 		if(dmRec != null && dmRec.count() > 0)
                 		{
                 			modelName = ifnull(dmRec.model_name,"").trim();
                 		}
                 	}
                 	vendor = "";
                 	createDeviceUuid = "";
                 	if(modelName == "OMNY M2")
                 	{
                 		vendor = "Yantrr";
                 		createDeviceUuid = ifnull(invItem.device_unique_id,"").trim();
                 	}
                 	else if(modelName == "RemSync")
                 	{
                 		vendor = "Silicon";
                 		createDeviceUuid = ifnull(invItem.device_unique_id,"").trim();
                 	}
                 	else
                 	{
                 		result.put("code",400);
                 		result.put("message","Unknown device model mapping: " + modelName);
                 		return result;
                 	}
                 	if(createDeviceUuid == "")
                 	{
                 		result.put("code",400);
                 		result.put("message","Missing device unique id");
                 		return result;
                 	}
                 	getUrl = "/api/remotecaredevices?query=status=unassigned%26asset_tag_id=" + assetTag + "&page=1&size=100";
                 	getMap = thisapp.fn_invokeapi(getUrl,"GET",null);
                 	getStatus = 0;
                 	deviceRecordId = 0;
                 	if(getMap != null)
                 	{
                 		getStatus = getMap.get("responseCode");
                 		if(getStatus == 200 || getStatus == 201)
                 		{
                 			getData = getMap.get("data");
                 			if(getData != null && getData.size() > 0)
                 			{
                 				firstRow = getData.get(0);
                 				deviceRecordId = firstRow.get("id");
                 				if(deviceRecordId != null)
                 				{
                 					result.put("code",getStatus);
                 					result.put("device_record_id",deviceRecordId);
                 					result.put("message","Success");
                 					result.put("data",getData);
                 					return result;
                 				}
                 			}
                 		}
                 		else
                 		{
                 			result.put("code",getStatus);
                 			result.put("device_record_id",deviceRecordId);
                 			result.put("message",getMap.get("responseText").toMap().get("detail"));
                 			return result;
                 		}
                 	}
                 	postUrl = "/api/remotecaredevices";
                 	postPayload = Map();
                 	postPayload.put(if(vendor == "Silicon","device_unique_id","device_id"),createDeviceUuid);
                 	postPayload.put("asset_tag_id",assetTag);
                 	postPayload.put("vendor",vendor);
                 	postPayload.put("status","unassigned");
                 	postMap = thisapp.fn_invokeapi(postUrl,"POST",postPayload);
                 	postStatus = 0;
                 	if(postMap != null)
                 	{
                 		postStatus = getMap.get("responseCode");
                 		if(postStatus == 200 || postStatus == 201)
                 		{
                 			postData = postMap.get("responseText");
                 			postId = null;
                 			if(postData != null)
                 			{
                 				postId = postData.get("id");
                 			}
                 			if(postId != null)
                 			{
                 				result.put("code",postStatus);
                 				result.put("device_record_id",postId);
                 				result.put("message","Success");
                 				return result;
                 			}
                 		}
                 		else
                 		{
                 			result.put("code",postStatus);
                 			result.put("device_record_id",deviceRecordId);
                 			result.put("message",getMap.get("responseText").toMap().get("detail"));
                 			return result;
                 		}
                 	}
                 	errMsg = ifnull(postMap.get("message"),"");
                 	if(errMsg == "")
                 	{
                 		errMsg = postMap + "Unable to resolve RemoteCare device record for asset tag " + assetTag + " (lookup status: " + getStatus + ", create status: " + postStatus + ")" + " get payload" + getUrl + " post payload" + postPayload + " get response:" + getMap + " post reponse:" + postMap;
                 	}
                 	result.put("code",postStatus);
                 	result.put("message",errMsg);
                 	return result;
                 }
				 void fn_setKitStatus(bigint kitID, string statusType)
                 {
                 	if(statusType == "INVENTORY")
                 	{
                 		kitStatus = "AVAILABLE";
                 		itemStatus = "IN KIT";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "ALLOCATED")
                 	{
                 		kitStatus = "ALLOCATED";
                 		itemStatus = "ALLOCATED";
                 		kitLoc = Location[location_name == "Patient"].ID;
                 	}
                 	else if(statusType == "STERLIZE")
                 	{
                 		kitStatus = "TO BE STERILIZED";
                 		itemStatus = "TO BE STERILIZED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "RETURN")
                 	{
                 		kitStatus = "RETURNED";
                 		itemStatus = "RETURNED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "OFFBOARD")
                 	{
                 		kitStatus = "OFFBOARDED";
                 		itemStatus = "OFFBOARDED";
                 		kitLoc = Location[location_name == "VMC"].ID;
                 	}
                 	else if(statusType == "LOST")
                 	{
                 		kitStatus = "LOST";
                 		itemStatus = "LOST";
                 		kitLoc = "";
                 	}
                 	else if(statusType == "PAUSED")
                 	{
                 		kitStatus = "SERVICE PAUSED";
                 		itemStatus = "ALLOCATED";
                 		kitLoc = Location[location_name == "Patient"].ID;
                 	}
                 	else
                 	{
                 		return;
                 	}
                 	kitRec = kit[ID = kitID];
                 	if(kitRec != null && kitRec.count() > 0)
                 	{
                 		kitRec.kit_status=kitStatus;
                 		kitRec.notes=kitStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + kitRec.notes;
                 		invItem = inventory_items[ID == kitRec.hub_item1];
                 		if(invItem != null && invItem.count() > 0)
                 		{
                 			invItem.status=itemStatus;
                 		}
                 		bagRec = bags[ID == kitRec.bag1.ID];
                 		if(bagRec != null && bagRec.count() > 0)
                 		{
                 			bagRec.status=itemStatus;
                 			bagRec.notes=itemStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + bagRec.notes;
                 		}
                 		for each  kt in kitRec.Kit_Items
                 		{
                 			// ← iterate from the fetched record, not input
                 			if(kt.inventory_items != null)
                 			{
                 				invItem = inventory_items[ID == kt.inventory_items.ID && Peripheral_Type == kt.Peripheral_Type.ID];
                 				if(invItem.count() > 0)
                 				{
                 					invItem.status=itemStatus;
                 					invItem.notes=itemStatus + ": Kit " + kitID + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | " + invItem.notes;
                 				}
                 			}
                 		}
                 	}
                 }
				 void handle_transition(string transitionName)
                 {
                 }
				 int Reports.rep_noofstatuscounts(string statustype)
                 {
                 	return kit_issues[distribution_status == statustype].count();
                 }
			 }
		 }
