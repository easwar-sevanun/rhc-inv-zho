										{
											alert "Row for " + row.old_inventory_item.serial_number + " cannot be deleted. Use remove item checkbox to remove from kit.";
											reRow = Kit_Replace.Replace_Items();
											reRow.Peripheral_Type=row.Peripheral_Type;
