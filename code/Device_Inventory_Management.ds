										}
										if(row.old_item_condition == "FAULTY")
										{
											row.old_item_new_status="IN SERVICE";
										}
										if(row.old_item_condition == "OK")
										{
											row.old_item_new_status="IN STOCK";
										}
						)
					}
				}

			}
