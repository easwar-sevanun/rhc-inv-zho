			kitdist_savesuccess as "kitdist_savesuccess"
			{
				type =  form
				form = kit_issues

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											kitRec = kit[ID = input.kit];
										if(kitRec != null && kitRec.count() > 0)
										{
											kitRec.kit_status="ALLOCATED";
											invItem = inventory_items[ID == kitRec.hub_item1];
											if(invItem != null && invItem.count() > 0)
											{
												invItem.status="ALLOCATED";
											}
											bagRec = bags[ID == kitRec.bag1.ID];
											if(bagRec != null && bagRec.count() > 0)
											{
												bagRec.status="ALLOCATED";
											}
											for each  kt in kitRec.Kit_Items
											{
												// ← iterate from the fetched record, not input
												if(kt.inventory_items != null)
												{
													invItem = inventory_items[ID == kt.inventory_items.ID && Peripheral_Type == kt.Peripheral_Type.ID];
													if(invItem.count() > 0)
													{
														invItem.status="ALLOCATED";
														invItem.notes=invItem.notes + " | Issued: Kit " + input.kit + " deleted on " + zoho.currentdate.toString("dd-MMM-yyyy");
													}
												}
											}
										}
										launcherRec = kit_issues[ID == input.ID];
										if(launcherRec != null)
										{
											baseUrl = zoho.appuri;
											if(!baseUrl.endsWith("/"))
											{
												baseUrl = baseUrl + "/";
											}
											openUrl(baseUrl + "#Report:All_Kit_Delivery_Report","same window");
										}
						)
					}
				}

			}
			kitdist_onvalidate as "kitdist_onvalidate"
			{
				type =  form
				form = kit_issues

				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.distribution_status != "ALLOCATED")
										{
											alert "Status should be issued";
											cancel submit;
										}
										if(input.kit == null)
										{
											alert "Kit not selected";
											cancel submit;
										}
										if(input.hospital1 == null)
										{
											alert "Select Hospital";
											cancel submit;
										}
										if(input.care_taker_name1 == null || input.care_taker_name1.trim() == "" && input.attendant_name1 == null || input.attendant_name1.trim() == "")
										{
											alert "Enter either care taker or attendant name";
											cancel submit;
										}
						)
					}
				}

			}
