												input.old_hub = kt.hub_item1;
												input.new_hub = kt.hub_item1;
												// Show condition/status fields for bag if kit has a bag
												if(kt.bag1 != null)
												{
													show bag_condition;
													show bag_new_status;
												}
												// Show condition/status fields for hub if kit has a hub
												if(kt.hub_item1 != null)
												{
													show hub_condition;
													show hub_new_status;
												}
											}
										}
						)
					}
				}

			}
