			Kit_Replace_PeripheralFil as "Kit_Replace_PeripheralFilter"
			{
				type =  form
				form = Kit_Replace

				record event = on add or edit

				on user input of Replace_Items.Peripheral_Type
				{
					actions 
					{
						custom deluge script
						(
											// Clear both item pickers when type changes
										//row.old_inventory_item=null;
										row.new_inventory_item=null;
										if(row.Peripheral_Type != null)
										{
											ptypeId = row.Peripheral_Type;
											if(row.Peripheral_Type.ID != null)
											{
												ptypeId = row.Peripheral_Type.ID;
											}
											// old_inventory_item: all peripherals of this type (regardless of status - item may be IN KIT)
											/*oldIds = inventory_items[device_category == "PERIPHERAL" && Peripheral_Type == ptypeId].ID.getAll();
																			if(oldIds != null && oldIds.size() > 0)
																			{
																				row.old_inventory_item:ui.add(oldIds);
																			}*/
											// new_inventory_item: only IN STOCK peripherals of this type
											newIds = inventory_items[device_category == "PERIPHERAL" && status == "IN STOCK" && Peripheral_Type == ptypeId].ID.getAll();
											if(newIds != null && newIds.size() > 0)
											{
												row.new_inventory_item:ui.add(newIds);
											}
										}
										// Only apply for new rows — pre-populated rows have old_inventory_item set
										if(row.old_inventory_item == null && row.Peripheral_Type != null)
										{
											selectedTypeId = row.Peripheral_Type;
											if(row.Peripheral_Type.ID != null)
											{
												selectedTypeId = row.Peripheral_Type.ID;
											}
											// Count how many rows in Replace_Items have this Peripheral_Type
											// If count > 1, another row already has it
											typeCount = 0;
											for each  r in input.Replace_Items
											{
												rTypeId = r.Peripheral_Type;
												if(r.Peripheral_Type.ID != null)
												{
													rTypeId = r.Peripheral_Type.ID;
												}
												if(rTypeId == selectedTypeId)
												{
													typeCount = typeCount + 1;
												}
											}
											if(typeCount > 1)
											{
												alert "This Peripheral Type is already present in another row. Please select a different type.";
												row.Peripheral_Type=null;
												row.new_inventory_item=null;
											}
											else
											{
												// Filter Peripheral_Type picklist to exclude already-used types for this row
												usedTypeIds = List();
												for each  r in input.Replace_Items
												{
													if(r.Peripheral_Type != null)
													{
														rTypeId = r.Peripheral_Type;
														if(r.Peripheral_Type.ID != null)
														{
															rTypeId = r.Peripheral_Type.ID;
														}
														if(rTypeId != selectedTypeId)
														{
															usedTypeIds.add(rTypeId);
														}
													}
												}
												allTypes = Peripheral_Type[ID != null].ID.getAll();
												availableIds = List();
												for each  typeId in allTypes
												{
													if(!usedTypeIds.contains(typeId))
													{
														availableIds.add(typeId);
													}
												}
												if(availableIds.size() > 0)
												{
													row.Peripheral_Type:ui.add(availableIds);
												}
												row.Peripheral_Type=ptypeId;
											}
										}
						)
					}
				}

			}
			Kit_Replace_Validate as "Kit_Replace_Validate"
			{
				type =  form
				form = Kit_Replace

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_ref == null)
										{
											alert "Please select a Kit.";
											cancel submit;
										}
										if(input.replace_reason == null || input.replace_reason == "")
										{
											alert "Please select a reason for replacement.";
											cancel submit;
										}
										// Prevent manual deletion of pre-populated peripheral rows
										kt = kit[ID == input.kit_ref];
										if(Kit_Distribution_ID != null || Kit_Distribution_ID.trim() != "")
										{
											if(date_of_reissue1 == null)
											{
												alert "Please select reissue date";
												cancel submit;
											}
										}
										if(kt != null)
										{
											for each  kiRow in kt.Kit_Items
											{
												found = false;
												for each  riRow in input.Replace_Items
												{
													if(riRow.old_inventory_item == kiRow.inventory_items)
													{
														found = true;
													}
												}
												if(found == false)
												{
													alert "Row for " + kiRow.inventory_items.serial_number + " cannot be manually deleted. Leave the new item blank to remove it — the row will be auto-removed on save.";
													cancel submit;
												}
											}
										}
										// Validate bag
										bagChanging = input.old_bag != null && input.new_bag != input.old_bag;
										bagRemoving = input.old_bag != null && input.new_bag == null;
										if(bagChanging || bagRemoving)
										{
											if(input.bag_condition == null)
											{
												alert "Please select the condition of the bag being removed.";
												cancel submit;
											}
											if(input.bag_new_status == null)
											{
												alert "Please select where the removed bag should go.";
												cancel submit;
											}
										}
										// Validate hub
										hubChanging = input.old_hub != null && input.new_hub != input.old_hub;
										hubRemoving = input.old_hub != null && input.new_hub == null;
										if(hubChanging || hubRemoving)
										{
											if(input.hub_condition == null)
											{
												alert "Please select the condition of the hub being removed.";
												cancel submit;
											}
											if(input.hub_new_status == null)
											{
												alert "Please select where the removed hub should go.";
												cancel submit;
											}
											if(input.new_hub != null)
											{
												newHubKitCount = kit[hub_item1 == input.new_hub && ID != input.kit_ref].count();
												if(newHubKitCount > 0)
												{
													alert "The selected new Hub is already assigned to another kit.";
													cancel submit;
												}
											}
										}
										// Ensure at least one thing is being replaced
										hasChange = false;
										if(input.old_bag != null && input.new_bag != input.old_bag)
										{
											hasChange = true;
										}
										if(input.old_bag == null && input.new_bag != null)
										{
											hasChange = true;
										}
										if(input.old_hub != null && input.new_hub != input.old_hub)
										{
											hasChange = true;
										}
										if(input.old_hub == null && input.new_hub != input.old_hub)
										{
											hasChange = true;
										}
										if(input.Replace_Items.count() > 0)
										{
											hasChange = true;
										}
										if(hasChange == false)
										{
											alert "Please fill in at least one item to replace or remove.";
											cancel submit;
										}
										// Validate each Replace_Items row
										seenNew = List();
										for each  riRow in input.Replace_Items
										{
											// Skip completely blank rows — no old and no new
											if(riRow.old_inventory_item == null && riRow.new_inventory_item == null)
											{
												continue;
											}
											// Old item present (removal or replacement) — require condition and destination
											if(riRow.old_inventory_item != null && riRow.Remove_Item == true)
											{
												if(riRow.old_item_condition == null)
												{
													alert "Please select the condition for each removed peripheral.";
													cancel submit;
												}
												if(riRow.old_item_new_status == null)
												{
													alert "Please select where each removed peripheral should go.";
													cancel submit;
												}
											}
											// New item present — validate uniqueness and kit assignment
											if(riRow.new_inventory_item != null)
											{
												if(riRow.new_inventory_item == riRow.old_inventory_item)
												{
													alert "New item cannot be the same as the current item in a peripheral row.";
													cancel submit;
												}
												if(seenNew.contains(riRow.new_inventory_item))
												{
													alert "The same new peripheral item cannot be used in multiple rows.";
													cancel submit;
												}
												newPerKitCount = kit[Kit_Items.inventory_items == riRow.new_inventory_item].count();
												if(newPerKitCount > 0)
												{
													alert "A selected new peripheral is already assigned to another kit.";
													cancel submit;
												}
												seenNew.add(riRow.new_inventory_item);
											}
										}
						)
					}
				}

			}
			Kit_Replace_AutoID as "Kit_Replace_AutoID"
			{
				type =  form
				form = Kit_Replace

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											year_val = zoho.currentdate.toString("yyyy");
										month_val = zoho.currentdate.toString("MM");
										count_val = Kit_Replace[replace_id != ""].count() + 1;
										input.replace_id = "KRP-" + year_val + "-" + month_val + "-" + count_val.toString("000");
										hide bag_condition;
										hide bag_new_status;
										hide hub_condition;
										hide hub_new_status;
										hide Replace_Items.New_Row;
										disable replace_id;
										disable kit_ref;
										disable Kit_Status;
										disable Kit_Distribution_ID;
										disable Kit_Distribution_Status;
										hide Kit_Distribution_Status;
										// input.kit_ref is set from initial value = "${kit_ref}" URL param before on load fires
										if(input.kit_ref != null)
										{
											if(input.Kit_Distribution_ID != null)
											{
												ki = kit_issues[provision_id == input.Kit_Distribution_ID && kit == input.kit_ref];
												if(ki.count() > 0)
												{
													kt = kit[ID == input.kit_ref];
												}
											}
											else
											{
												hide date_of_reissue1;
												kt = kit[ID == input.kit_ref];
											}
											if(kt != null || kt.count() > 0)
											{
												input.Kit_Status = kt.kit_status;
												input.old_bag = kt.bag1;
												input.new_bag = kt.bag1;
												input.old_hub = kt.hub_item1;
												input.new_hub = kt.hub_item1;
												if(kt.bag1 != null)
												{
													show bag_condition;
													show bag_new_status;
												}
												if(kt.hub_item1 != null)
												{
													show hub_condition;
													show hub_new_status;
												}
												// Pre-populate Replace_Items from kit's current peripherals
												input.Replace_Items.clear();
												for each  kiRow in kt.Kit_Items
												{
													newRow = Kit_Replace.Replace_Items();
													newRow.Peripheral_Type=kiRow.Peripheral_Type;
													newRow.old_inventory_item=kiRow.inventory_items;
													input.Replace_Items.insert(newRow);
												}
												for each  row in input.Replace_Items
												{
													disable Replace_Items.Peripheral_Type;
													disable Replace_Items.old_inventory_item;
												}
											}
										}
						)
					}
				}

			}
			Kit_Replace_OnSuccess1 as "Kit_Replace_OnSuccess"
			{
				type =  form
				form = Kit_Replace

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											ktRec = kit[ID == input.kit_ref];
										if(ktRec != null)
										{
											if(Kit_Distribution_ID == null)
											{
												kitIsIssued = ktRec.kit_status == "ALLOCATED" || ktRec.kit_status == "EXTENDED";
											}
											else
											{
												kitIsIssued = true;
											}
											auditNote = "Kit " + ktRec.kit_code + " | " + zoho.currentdate.toString("dd-MMM-yyyy") + "|" + zoho.currenttime.toString("HH:MM:SS") + " | Reason: " + input.replace_reason;
											// ── BAG ──────────────────────────────────────────────
											if(input.old_bag != null && input.new_bag != input.old_bag)
											{
												oldBagRec = bags[ID == input.old_bag];
												if(oldBagRec != null)
												{
													oldBagRec.status=input.bag_new_status;
													oldBagRec.notes="Removed from " + auditNote + " | Condition: " + input.bag_condition;
												}
												ktRec.bag1=null;
												if(input.new_bag != null)
												{
													newBagRec = bags[ID == input.new_bag];
													if(newBagRec != null)
													{
														//newBagRec.status=ktRec.kit_status;
														newBagRec.status=if(kitIsIssued,"ALLOCATED","IN KIT");
													}
													ktRec.bag1=input.new_bag;
												}
											}
											// ── HUB ──────────────────────────────────────────────
											if(input.old_hub != null && input.new_hub != input.old_hub)
											{
												oldHubRec = inventory_items[ID == input.old_hub];
												if(oldHubRec != null)
												{
													oldHubRec.status=input.hub_new_status;
													oldHubRec.notes="Removed from " + auditNote + " | Condition: " + input.hub_condition;
												}
												ktRec.hub_item1=null;
												if(input.new_hub != null)
												{
													newHubRec = inventory_items[ID == input.new_hub];
													if(newHubRec != null)
													{
														//newHubRec.status=ktRec.kit_status;
														if(kitIsIssued)
														{
															kd = kit_issues[provision_id == input.Kit_Distribution_ID];
															thisapp.fn_kit_reassign(kd.ID,kd.replacement_date1,kd.replacement_date1,1);
														}
														newHubRec.status=if(kitIsIssued,"ALLOCATED","IN KIT");
													}
													ktRec.hub_item1=input.new_hub;
												}
											}
											// ── PERIPHERAL ITEMS ─────────────────────────────────
											revKitItems = Collection();
											for each  riRow in input.Replace_Items
											{
												// Skip fully blank rows
												if(riRow.old_inventory_item == null && riRow.new_inventory_item == null)
												{
													continue;
												}
												// ── Scenario 1: Removal only (old set, no new) ──
												if(riRow.old_inventory_item != null && riRow.new_inventory_item == null)
												{
													oldPerRec = inventory_items[ID == riRow.old_inventory_item];
													if(riRow.Remove_Item == true)
													{
														if(oldPerRec != null || oldPerRec.count() > 0)
														{
															oldPerRec.status=riRow.old_item_new_status;
															oldPerRec.notes="Removed from " + auditNote + " | Condition: " + riRow.old_item_condition;
														}
														//Dont add to revKitItems as the item is getting removed
													}
													else
													{
														oldKitRow = kit.Kit_Items();
														oldKitRow.Peripheral_Type=riRow.Peripheral_Type;
														oldKitRow.inventory_items=riRow.old_inventory_item;
														revKitItems.insert(oldKitRow);
													}
												}
												// ── Scenario 2: Add only (no old, new set) ──
												if(riRow.old_inventory_item == null && riRow.new_inventory_item != null)
												{
													newPerRec = inventory_items[ID == riRow.new_inventory_item];
													if(newPerRec != null || newPerRec.count() > 0)
													{
														newPerRec.status=if(kitIsIssued,"ALLOCATED","IN KIT");
														//newPerRec.status=ktRec.kit_status;
														newPerRec.notes="Added to " + auditNote;
														newKitRow = kit.Kit_Items();
														newKitRow.Peripheral_Type=riRow.Peripheral_Type;
														newKitRow.inventory_items=riRow.new_inventory_item;
														revKitItems.insert(newKitRow);
													}
												}
												// ── Scenario 3: Replace (old and new both set) ──
												if(riRow.old_inventory_item != null && riRow.new_inventory_item != null)
												{
													// Remove old item
													oldPerRec = inventory_items[ID == riRow.old_inventory_item.ID];
													if(oldPerRec != null || oldPerRec.count() > 0)
													{
														oldPerRec.status=riRow.old_item_new_status;
														oldPerRec.notes="Removed from " + auditNote + " | Condition: " + riRow.old_item_condition;
													}
													// Insert new item into kit
													newPerRec = inventory_items[ID == riRow.new_inventory_item.ID];
													if(newPerRec != null || newPerRec.count() > 0)
													{
														newPerRec.status=if(kitIsIssued,"ALLOCATED","IN KIT");
														//newPerRec.status=ktRec.kit_status;
														newPerRec.notes="Replaced in " + auditNote;
														newKitRow = kit.Kit_Items();
														newKitRow.Peripheral_Type=riRow.Peripheral_Type;
														newKitRow.inventory_items=riRow.new_inventory_item;
														revKitItems.insert(newKitRow);
													}
												}
											}
											if(revKitItems.size() > 0)
											{
												ktRec.Kit_Items.clear();
												ktRec.Kit_Items.insert(revKitItems);
												ktRec.notes="Kit items updates " + auditNote;
												input.Replace_Items.clear();
											}
										}
						)
					}
				}

			}
