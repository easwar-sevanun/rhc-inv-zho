			total_loss_onsubmission as "total_loss_onsubmission"
			{
				type =  form
				form = Total_Loss

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											kd = kit_issues[provision_id = input.Kit_Distribution_ID && kit.ID = input.kit_ref];
										kd.notes="Kit loss: Reason:" + input.loss_reason + " | Notes:" + input.notes + " | Kit ID:" + input.kit_ref.kit_code + "| reported on " + zoho.currentdate.toString("dd-MMM-yyyy") + " | ";
										kd.distribution_status="LOST";
										kd.offboarding_date1=input.date_of_loss1;
										thisapp.fn_setKitStatus(input.kit_ref,"LOST");
						)
					}
				}

			}
			Kit_Replace_Validate4 as "Kit_Replace_Validate"
			{
				type =  form
				form = Total_Kit_Replacement

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_ref == null || input.kit == null || input.kit.toString().trim() == "")
										{
											alert "Please select a Kit.";
											cancel submit;
										}
										if(input.replacement_reason == null || input.replacement_reason.toString().trim() == "")
