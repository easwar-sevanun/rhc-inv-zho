 application "Device Inventory Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Calcutta"
 	time format = "24-hr"

 	forms
	{
		form App_Config
		{
			displayname = "App Config"
			success message = "Data Added Successfully!"
			Section1
			(
				type = section
				displayname = "Section"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have config_key
			(
    			type = text
				displayname = "Config Key"
	 			row = 1
	 			column = 1   
				width = medium
			)
			config_value
			(
    			type = textarea
				displayname = "Config Value"
				height = 100px
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Section
			(
				type = section
	 			row = 2
	 			column = 0   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form bags
		{
			displayname = "Bags"
			success message = "Bag Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			bag_tag
			(
    			type = text
				displayname = "Bag Tag"
				qrcode = true
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"IN STOCK","IN KIT","ALLOCATED","TO BE STERILIZED","RETURNED","LOST","DAMAGED","IN SERVICE"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Change_SIM
		{
			displayname = "Change SIM"
			success message = "Data Updated Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have sim_change_hub
			(
				type = picklist	
				displayname = "Hub"
				values  = inventory_items[device_category == "HUB"].ID
    			displayformat = [serial_number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			current_sim
			(
    			type = text
				displayname = "Current SIM"
	 			row = 1
	 			column = 1   
				width = medium
			)
			new_sim_card
			(
				type = picklist	
				displayname = "New SIM"
				values  = sim_cards[status == "AVAILABLE" || status == "ACTIVE"].ID
    			displayformat = [sim_number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have change_reason
			(
				type = picklist
				displayname = "Change Reason"
				maxchar = 100
				values = {"SIM Problem","Normal Change"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			remove_sim
			(
    			type = checkbox
				displayname = "Proceed to remove SIM from hub"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			change_notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form device_models
		{
			displayname = "Device Models"
			success message = "Device Model Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			device_category
			(
				type = radiobuttons
				displayname = "Device Category"
				values = {"HUB","PERIPHERAL"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			model_name
			(
    			type = text
				displayname = "Model Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			peripheral_type1
			(
				type = picklist	
				displayname = "Peripheral Type"
				values  = Peripheral_Type.ID
    			displayformat = [peripheral_type]
				allow new entries
				[
					displayname = "Add New"
					set values
					(
						peripheral_type = input.peripheral_type1
					)
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			manufacturer
			(
    			type = text
				displayname = "Manufacturer"
	 			row = 1
	 			column = 1   
				width = medium
			)
			year_1
			(
				type = number
				displayname = "Year"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			default_hw_version
			(
    			type = text
				displayname = "Default Hardware Version"
	 			row = 1
	 			column = 1   
				width = medium
			)
			default_fw_version
			(
    			type = text
				displayname = "Default Firmware Version"
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form kit_issues
		{
			title 
    		{
				displayname = "Distribute Kit"
    			on add = "Distribute Kit - New"
   	 			on edit = "Distribute Kit - Edit"
			}
			success message = "Kit Issue Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			kit
			(
				type = picklist	
				displayname = "Kit"
				values  = kit[kit_status == "AVAILABLE"].ID
    			displayformat = [kit_code]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			patient_search
			(
    			type = text
				displayname = "Search Patient"
	 			row = 1
	 			column = 1   
				width = medium
			)
			gender
			(
				type = picklist
				displayname = "Gender"
				values = {"Male","Female","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			uhid
			(
    			type = text
				displayname = "UHID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			phone3
			(
    			type = phonenumber
				displayname = "Phone 3"
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			onboarding_date1
			(
    			type = date
				displayname = "Onboarding Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			distribution_status
			(
				type = picklist
				displayname = "Status"
				values = {"ALLOCATED","ONBOARDED","EXTENDED","REPLACEMENT","OFFBOARDED","RETURNED","CLOSED","LOST"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			patient_name
			(
    			type = text
				displayname = "Patient Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			doctor
			(
				type = picklist	
				displayname = "Doctor"
				values  = Doctors_List.ID
    			displayformat = [" " + name.prefix + " " + name.first_name + " " + name.last_name + " " + name.suffix]
				allow new entries
				[
					displayname = "Add New"
					set values
					(
						name.first_name = input.doctor
					)
				]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			phone1
			(
    			type = phonenumber
				displayname = "Phone 1"
	 			row = 1
	 			column = 2   
				width = medium
			)
			hospital1
			(
				type = picklist	
				displayname = "Hospital"
				values  = Hospital_List.ID
    			displayformat = [hospital_name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			kit_request_type1
			(
				type = radiobuttons
				displayname = "Kit Request Type"
				maxchar = 100
				values = {"Apollo","Kumaran SOG","Kumaran MOG","VHS"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			offboarding_date1
			(
    			type = date
				displayname = "Offboarding Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			provision_id
			(
    			type = text
				displayname = "Provision ID"
	 			row = 1
	 			column = 3   
				width = medium
			)
			age
			(
				type = number
				displayname = "Age"
				maxchar = 19
	 			row = 1
	 			column = 3   
				width = medium
			)
			patient_id1
			(
    			type = text
				displayname = "Patient ID"
	 			row = 1
	 			column = 3   
				width = medium
			)
			phone2
			(
    			type = phonenumber
				displayname = "Phone 2"
	 			row = 1
	 			column = 3   
				width = medium
			)
			address
			(
    			type = address
				displayname = "Address"
     			capture_coordinates = true
     			adjust_using_map = false
     			address_line_1
     			(
	     			  type = address_line_1
	     			  displayname = "Address Line 1"
     			) 
     			address_line_2
     			(
	     			  type = address_line_2
	     			  displayname = "Address Line 2"
     			) 
     			district_city
     			(
	     			  type = district_city
	     			  displayname = "City / District"
     			) 
     			state_province
     			(
	     			  type = state_province
	     			  displayname = "State / Province"
     			) 
     			postal_Code
     			(
	     			  type = postal_Code
	     			  displayname = "Postal Code"
     			) 
     			country
     			(
	     			  type = country
	     			  displayname = "Country"
	     			 visibility = false
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "Latitude"
	     			 visibility = false
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "Longitude"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 3   
				width = medium
			)
			patient_ref_id1
			(
    			type = text
				displayname = "Patient Ref ID"
	 			row = 1
	 			column = 3   
				width = medium
			)
			replacement_date1
			(
    			type = date
				displayname = "Replacement Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 3   
				width = medium
			)
			replacement_reason1
			(
				type = picklist
				displayname = "Replacement Reason"
				maxchar = 100
				values = {"Patient has recovered","Patient has passed away","Patient has opted-out of service","Device is faulty","Device is unused"}
	 			row = 1
	 			column = 3   
				width = medium
			)
			Patient_Results
			(
				type = grid
				displayname = "Search Results"
				values  = Patient_Results.ID
	 			row = 2
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Kit Issued","Kit Assigned","Kit Issue Pending Approval","Kit Issue Rejected","Kit Ready to Use","Kit Not Picked Up","Kit Issue Cancelled","Kit In Use","Kit Returned Early","Kit Returned","Kit Loss","Kit Damaged","Kit Inspected","Kit Not Returned","Kit Sent to Inventory","Kit Replaced","Kit Archived","Kit Reported Lost","Kit Available","Kit Reassigned","Replacement","Kit Offboard"}
			}
		}
		form Doctors_List
		{
			displayname = "Doctors List"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			name
			(
    			type = name
				displayname = "Name"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_active
			(
    			type = checkbox
				displayname = "Is Active"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Hospital_List
		{
			displayname = "Hospital List"
			success message = "Hospital List Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			hospital_name
			(
    			type = text
				displayname = "Hospital Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form hub_sim_assignments
		{
			displayname = "Hub SIM Assignments"
			success message = "Hub Sim Assignment Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			hub_item
			(
				type = picklist	
				displayname = "Hub Item"
				values  = inventory_items[device_category == "HUB" && active_sim_number.sim_number is null].ID
    			displayformat = [serial_number]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			sim_card
			(
				type = picklist	
				displayname = "SIM Card"
				values  = sim_cards[status == "ACTIVE"].ID
    			displayformat = [sim_number]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_on
			(
    			type = datetime
				displayname = "Assigned On"
				initial value = "${zoho.currenttime}"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_by
			(
    			type = text
				displayname = "Assigned By"
				initial value = "${zoho.loginuser}"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form inventory_items
		{
			displayname = "Inventory Items"
			success message = "Inventory Item Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			device_category
			(
				type = radiobuttons
				displayname = "Device Category"
				values = {"HUB","PERIPHERAL"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			device_model1
			(
				type = picklist	
				displayname = "Device Model"
				values  = device_models[device_category == input.device_category].ID
    			displayformat = [model_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique serial_number
			(
    			type = text
				displayname = "Serial Number"
				qrcode = true
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			fw_version
			(
    			type = text
				displayname = "Firmware Version"
	 			row = 1
	 			column = 1   
				width = medium
			)
			previous_active_sim
			(
				type = picklist	
				displayname = "Previous Active SIM"
				values  = sim_cards.ID
    			displayformat = [sim_number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"IN STOCK","IN KIT","ALLOCATED","TO BE STERILIZED","RETURNED","LOST","DAMAGED","IN SERVICE"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Peripheral_Type
			(
				type = picklist	
				displayname = "Peripheral Type"
				values  = Peripheral_Type.ID
    			displayformat = [peripheral_type]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			internal_barcode
			(
    			type = text
				displayname = "Barcode"
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			device_unique_id
			(
    			type = text
				displayname = "Device Unique ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			current_location
			(
    			type = text
				displayname = "Current Location"
	 			row = 1
	 			column = 2   
				width = medium
			)
			sim_change_reason
			(
    			type = textarea
				displayname = "SIM Change Reason"
				height = 80px
	 			row = 1
