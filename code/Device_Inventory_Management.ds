			hub_sim_assignments_onsuc as "hub_sim_assignments_onsuccess"
			{
				type =  form
				form = hub_sim_assignments

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											simRec = sim_cards[ID == input.sim_card];
										if(simRec != null)
										{
											simRec.status="IN KIT";
										}
										hubRec = inventory_items[ID == input.hub_item];
										if(hubRec != null)
										{
											hubRec.active_sim_number=input.sim_card;
										}
						)
