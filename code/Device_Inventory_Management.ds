								custom deluge script
								(
															thisapp.fn_setKitStatus(input.kit,"ALLOCATED");
														if(input.kit_request_type1 == "Apollo")
														{
															input.hospital1 = Hospital_List[hospital_name == "Apollo"].ID;
														}
														else if(input.kit_request_type1 == "Kumaran SOG" || input.kit_request_type1 == "Kumaran MOG")
														{
															input.hospital1 = Hospital_List[hospital_name == "Kumaran"].ID;
														}
														else if(input.kit_request_type1 == "VHS")
														{
															input.hospital1 = Hospital_List[hospital_name == "VHS"].ID;
														}
														else
														{
															input.hospital1 = Hospital_List[hospital_name == "Other"].ID;
														}
														if(kit_request_type1 == null || kit_request_type1 == "" || advance_amount == null || Kit_Collection_Date == null || Kit_Collection_Date.toString() == "")
														{
															input.notes = thisapp.errMsg("Input missing for Request type / advance amount / collection date");
															thisapp.blueprint.changeStage("kit_issues","kit_issue_and_return_process","Kit Available",input.ID);
