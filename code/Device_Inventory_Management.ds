    				Resume_Service as "Resume Service"
    				{
         				type = normal
         				from stage = "Pause/Resume Service"
         				to stage = "Kit In Use"
         				before
         				{
         				}
         				during
         				{
            				action = update_fields
            				workflow status = true
            				visible fields = [resume_date,resume_notes_input]
         				}
         				after
         				{
							actions 
							{
								custom deluge script
								(
															if(resume_date != null && resume_date.toString() != "")
														{
															col = Collection();
															for each  row in input.kit_service_pause_encounters
															{
																eRow = kit_issues.kit_service_pause_encounters();
																eRow.Paused_at=row.Paused_at;
																eRow.Pause_reason=row.Pause_reason;
																if(row.Is_Open == true)
																{
																	eRow.Resumed_at=input.resume_date;
																	eRow.Resume_Notes=ifnull(input.resume_notes_input,"");
																	eRow.Is_Open=false;
																}
																else
																{
																	eRow.Resumed_at=row.Resumed_at;
																	eRow.Resume_Notes=row.Resume_Notes;
																	eRow.Is_Open=row.Is_Open;
																}
																col.insert(eRow);
															}
															input.kit_service_pause_encounters.clear();
															input.kit_service_pause_encounters.insert(col);
															input.distribution_status = "ALLOCATED";
															thisapp.fn_setKitStatus(input.kit,"ALLOCATED");
															input.resume_notes_input = "";
															apiUrl = "/api/remotecareprofiles/" + input.patient_ref_id1;
															rcpdPayload = Map();
															rcpdPayload.put("status",1);
															responseMap = thisapp.fn_invokeapi(apiUrl,"PUT",rcpdPayload);
															if(responseMap != null)
															{
																postStatus = responseMap.get("responseCode");
																if(postStatus == 200 || postStatus == 201)
																{
																	input.notes = thisapp.errMsg("Service Resumed");
																}
																else
																{
																	input.notes = thisapp.errMsg("Error resuming service");
																	thisapp.blueprint.changeStage("kit_issues","kit_issue_and_return_process","Pause/Resume Service",input.ID);
																}
															}
														}
														else
														{
															input.notes = thisapp.errMsg("Resume date mandatory");
															thisapp.blueprint.changeStage("kit_issues","kit_issue_and_return_process","Pause/Resume Service",input.ID);
														}
								)
							}
         				}
         				chart data
         				{
             				from port : B4
             				to port   : B4
             				path      : [-392.5280797284045,548.6078297952216,-392.5280797284045,558.6078297952216,-576.2845954034462,558.6078297952216,-576.2845954034462,523.0244964618882,-576.2845954034462,487.4411631285549,-576.2845954034462,477.4411631285549]
        				}
  				}
