 application "Device Inventory Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Calcutta"
 	time format = "24-hr"

 	forms
	{
		form App_Config
		{
			displayname = "App Config"
			success message = "Data Added Successfully!"
			Section1
			(
				type = section
				displayname = "Section"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique config_key
			(
    			type = text
				displayname = "Config Key"
	 			row = 1
	 			column = 1   
				width = medium
			)
			config_value
			(
    			type = textarea
				displayname = "Config Value"
				height = 100px
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Section
			(
				type = section
	 			row = 2
	 			column = 0   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form bags
		{
			displayname = "Bags"
			success message = "Bag Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique bag_tag
			(
    			type = text
				displayname = "Bag Tag"
				qrcode = true
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"IN STOCK","IN KIT","ALLOCATED","TO BE STERILIZED","RETURNED","LOST","DAMAGED","IN SERVICE"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Change_SIM
		{
			displayname = "Change SIM"
			success message = "Data Updated Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have sim_change_hub
			(
				type = picklist	
				displayname = "Hub"
				values  = inventory_items[device_category == "HUB"].ID
    			displayformat = [serial_number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			current_sim
			(
    			type = text
				displayname = "Current SIM"
	 			row = 1
	 			column = 1   
				width = medium
			)
			new_sim_card
			(
				type = picklist	
				displayname = "New SIM"
				values  = sim_cards[status == "AVAILABLE" || status == "ACTIVE"].ID
    			displayformat = [sim_number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have change_reason
			(
				type = picklist
				displayname = "Change Reason"
				maxchar = 100
				values = {"SIM Problem","Normal Change"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			remove_sim
			(
    			type = checkbox
				displayname = "Proceed to remove SIM from hub"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			change_notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
