			kit_patient_page_next as "kit_patient_page_next"
			{
				type =  form
				form = kit_issues

				record event = on add or edit

				on user input of patient_page_next
				{
					actions 
					{
						custom deluge script
						(
											if(input.patient_page_next == true)
										{
											input.patient_page_next = false;
											currentPage = ifnull(input.patient_search_page,0).toLong();
											totalPages = ifnull(input.patient_search_total_pages,1).toLong();
											if(currentPage < totalPages - 1)
											{
												nextPage = currentPage + 1;
												input.patient_search_page = nextPage;
												searchText = input.patient_search;
												apiUrl = "/api/userprofiles?page=" + nextPage + "&size=30&filter=userType='PATIENT' and firstName ilike '" + searchText + "'";
												responseMap = thisapp.fn_invokeapi(apiUrl,"GET",null);
												if(responseMap != null)
												{
													if(responseMap.get("responseCode") == 200 || responseMap.get("responseCode") == 201)
													{
														getdata = responseMap.get("responseText");
														if(getdata != null && getdata.size() > 0)
														{
															contentList = getdata.get("content");
															totalPages = ifnull(getdata.get("totalPages"),1);
															totalElements = ifnull(getdata.get("totalElements"),0);
															input.patient_search_total_pages = totalPages.toLong();
															input.patient_search_info = "Page " + (nextPage + 1) + " of " + totalPages + " (" + totalElements + " results)";
															input.Patient_Results.clear();
															if(contentList != null && contentList.size() > 0)
															{
																for each  patient in contentList
																{
																	patientMap = patient.toMap();
																	firstName = patientMap.get("firstName");
																	if(firstName == null)
																	{
																		firstName = "";
																	}
																	lastName = patientMap.get("lastName");
																	if(lastName == null)
																	{
																		lastName = "";
																	}
																	fullName = (firstName + " " + lastName).trim();
																	displayPatientId = patientMap.get("displayPatientId");
																	if(displayPatientId == null)
																	{
																		displayPatientId = "";
																	}
																	patientRecordId = "";
																	patientRecordId = patientMap.get("id");
																	hospitalIdsRaw = patientMap.get("hospitalIds");
																	if(hospitalIdsRaw != null)
																	{
																		hospitalIdsMap = hospitalIdsRaw.toMap();
																		uid = hospitalIdsMap.get("uniqueId");
																		if(uid != null)
																		{
																			uniqueId = uid.toString();
																		}
																	}
																	ageVal = patientMap.get("age");
																	ageStr = if(ageVal != null,ageVal.toString(),"");
																	genderVal = patientMap.get("gender");
																	if(genderVal == null)
																	{
																		genderVal = "";
																	}
																	else
																	{
																		genderVal = genderVal.proper();
																	}
																	phoneVal = patientMap.get("primaryNumber");
																	if(phoneVal == null)
																	{
																		phoneVal = "";
																	}
																	addressMap = patientMap.get("address").toMap().get("permanentAddress").toMap();
																	resultRow = kit_issues.Patient_Results();
																	resultRow.pr_select=false;
																	resultRow.pr_name=fullName;
																	resultRow.pr_patient_id=displayPatientId;
																	resultRow.pr_uhid=uniqueId;
																	resultRow.pr_age=ageStr;
																	resultRow.pr_gender=genderVal;
																	resultRow.pr_phone=phoneVal;
																	resultRow.patient_ref_id1=patientRecordId;
																	resultRow.Address.address_line_1=addressMap.get("addressLine1");
																	resultRow.Address.address_line_2=addressMap.get("addressLine2");
																	if(addressMap.get("city") != null || addressMap.get("city").trim() != "")
																	{
																		city = Map();
																		isMap = true;
																		try 
																		{
																			cityMap = addressMap.get("city").toMap();
																		}
																		catch (e)
																		{
																			isMap = false;
																		}
																		if(isMap && addressMap.get("city").toMap() != null)
																		{
																			resultRow.Address.district_city=addressMap.get("city").toMap().get("name");
																		}
																		else
																		{
																			resultRow.Address.district_city=addressMap.get("city");
																		}
																	}
																	else
																	{
																		resultRow.Address.district_city=addressMap.get("district");
																	}
																	if(addressMap.get("pincode") != null || addressMap.get("pincode").trim() != "")
																	{
																		resultRow.Address.postal_Code=addressMap.get("pincode");
																	}
																	if(addressMap.get("country") != null || addressMap.get("country").trim() != "")
																	{
																		resultRow.Address.country=addressMap.get("country");
																	}
																	if(addressMap.get("state") != null || addressMap.get("state").trim() != "")
																	{
																		//resultRow.Address.state_province=addressMap.get("state").toMap().get("name");
																		state = Map();
																		isMap = true;
																		try 
																		{
																			state = addressMap.get("state").toMap();
																		}
																		catch (e)
																		{
																			isMap = false;
																		}
																		if(isMap && state != null)
																		{
																			resultRow.Address.district_city=state.get("name");
																		}
																		else
																		{
																			resultRow.Address.district_city=addressMap.get("state");
																		}
																	}
																	input.Patient_Results.insert(resultRow);
																}
																disable Patient_Results.pr_name;
																disable Patient_Results.pr_patient_id;
																disable Patient_Results.pr_uhid;
																disable Patient_Results.pr_age;
																disable Patient_Results.pr_gender;
																disable Patient_Results.pr_phone;
																disable Patient_Results.Address;
																hide Patient_Results.Address;
																disable Patient_Results.pr_patient_id;
																hide Patient_Results.pr_patient_id;
															}
														}
													}
												}
											}
											else
											{
												alert "You are on the last page.";
											}
										}
						)
					}
				}

			}
			kit_patient_page_prev as "kit_patient_page_prev"
