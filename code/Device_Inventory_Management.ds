			check_barcode_map as "check_barcode_map"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				on user input of internal_barcode
				{
					actions 
					{
						custom deluge script
						(
											raw = input.internal_barcode.replaceAll("\n","").trim();
										if(raw != null && raw != "")
										{
											bc = raw;
											input.item_scan1 = bc;
											if(bc.length() > 7 && bc.left(7).lower() == "rcdsavn" || bc.left(6) == "230915")
											{
												input.device_category = "HUB";
												if(bc.left(7).lower() == "rcdsavn")
												{
													dm = device_models[device_category == "HUB" && model_name == "RemSync"];
												}
												else if(bc.left(6).lower() == "230915")
												{
													dm = device_models[device_category == "HUB" && model_name == "OMNY M2"];
												}
												if(dm.count() > 0)
												{
													input.device_model1 = dm.ID;
												}
												input.asset_tag = bc;
												hide peripheral_model;
												hide Peripheral_Type;
												show device_model1;
											}
											else
											{
												input.device_category = "PERIPHERAL";
												hide device_model1;
												show peripheral_model;
												show Peripheral_Type;
											}
											input.serial_number = bc;
											focus internal_barcode;
											input.internal_barcode = null;
											bc = null;
										}
						)
					}
				}

			}
			check_barcode_map1 as "check_barcode_map"
			{
				type =  form
				form = kit

				record event = on add or edit

				on user input of internal_barcode
				{
					actions 
					{
						custom deluge script
						(
											//alert  inventory_items[device_category == "PERIPHERAL" && Peripheral_Type = Peripheral_Type[peripheral_type == "BP Machine"] ];
										//device_category == "PERIPHERAL" && Peripheral_Type = Peripheral_Type[peripheral_type == "BP Machine"] && 
										//alert inventory_items[serial_number == input.internal_barcode] ;
										raw = input.internal_barcode.replaceAll("\n","").trim();
										if(raw != null && raw != "")
										{
											scannedCode = raw;
											matchedItem = inventory_items[serial_number == scannedCode];
											if(matchedItem.count() > 0)
											{
												input.item_scan1 = matchedItem.ID;
												if(scannedCode.length() > 7 && scannedCode.lower().left(7) == "rcdsavn" || scannedCode.lower().left(6) == "230915")
												{
													input.hub_item1 = inventory_items[serial_number == scannedCode].ID;
												}
												if(scannedCode.length() > 5 && scannedCode.lower().left(5) == "ktc -" || scannedCode.lower().left(4) == "ktc-")
												{
													input.kit_code = scannedCode;
												}
												else if(inventory_items[serial_number == scannedCode].count() > 0)
												{
													for each  row in input.Kit_Items
													{
														if(inventory_items[serial_number == scannedCode].Peripheral_Type == row.Peripheral_Type)
														{
															row.inventory_items=inventory_items[serial_number == scannedCode].ID;
														}
													}
												}
											}
											else
											{
												if(bags[bag_tag == scannedCode].count() > 0 && scannedCode.lower().left(3) == "bag")
												{
													input.bag1 = bags[bag_tag == scannedCode].ID;
												}
												else
												{
													alert "No item found for: " + scannedCode;
												}
											}
											input.internal_barcode = "";
											focus internal_barcode;
										}
						)
					}
				}

			}
