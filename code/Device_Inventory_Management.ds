			KIT_default_items as "KIT_default_items"
			{
				type =  form
				form = kit

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.Kit_Items.clear();
										defaultTypes = {"BP Machine","Oximeter","Thermometer"};
										for each  typeName in defaultTypes
										{
											pt = Peripheral_Type[peripheral_type == typeName];
											if(pt.count() > 0)
											{
												newRow = kit.Kit_Items();
												newRow.Peripheral_Type=pt.ID;
												input.Kit_Items.insert(newRow);
											}
										}
										for each  row in input.Kit_Items
										{
											row.inventory_items=null;
											itemIds = List();
											if(row.Peripheral_Type != null)
											{
												ptypeId = row.Peripheral_Type.ID;
												if(ptypeId == null)
												{
													ptypeId = row.Peripheral_Type;
												}
												itemIds = inventory_items[device_category == "PERIPHERAL" && status == "IN STOCK" && Peripheral_Type == ptypeId].ID.getAll();
											}
											if(itemIds != null && itemIds.size() > 0)
											{
												row.inventory_items:ui.add(itemIds);
											}
										}
						)
					}
				}

			}
