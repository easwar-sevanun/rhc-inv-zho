		list sim_cards_Report
		{
			displayName = "All Sim Cards"
			show all rows from sim_cards    
			(
				sim_number as "SIM Number"
				iccid as "Mobile No"
				activation_date as "Activation Date"
				operator as "Operator"
				plan_name as "Plan Name"
				status as "Status"
				notes as "Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "ACTIVE")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "AVAILABLE")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "SUSPENDED")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
