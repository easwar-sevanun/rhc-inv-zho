			kit_patient_search as "kit_patient_search"
			{
				type =  form
				form = kit_issues

				record event = on add or edit

				on user input of patient_search
				{
					actions 
					{
						custom deluge script
						(
											searchText = input.patient_search;
										if(searchText != null && searchText.length() >= 2)
										{
											tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
											if(tokenRec.config_value == null || tokenRec.config_value == "")
											{
												retstatus = thisapp.fn_getapitoken();
												if(retstatus.get("msg") == "Success")
												{
													tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
												}
												else
												{
													alert retstatus.get("msg");
												}
											}
											//tokenRec = thisapp.variables.EMR.EMR_BEARER_TOKEN;
											baseUrlRec = App_Config[config_key == "EMR_BASE_URL"];
											//baseUrlRec = thisapp.variables.EMR.EMR_BASE_URL;
											if(tokenRec.count() == 0 || baseUrlRec.count() == 0)
											{
												alert "Interface issue call application support.";
											}
											else
											{
												bearerToken = tokenRec.config_value;
												//bearerToken = tokenRec;
												emrBase = baseUrlRec.config_value;
												//emrBase = baseUrlRec;
												//filterJson = "{\"filter\":\"userType='PATIENT' and firstName ilike '" + searchText + "'\"}";
												//encodedFilter = encodeUrl(filterJson);
												//apiUrl = emrBase + "/api/userprofiles?page=0&size=20&searchParams=" + encodedFilter;
												apiUrl = emrBase + "/api/userprofiles?page=0&size=20&filter=userType='PATIENT' and firstName ilike '" + searchText + "'";
												//https://emrtest.sevanun.com/api/userprofiles?page=0&size=100&searchParams=%7B%20%22filter%22%3A%20%22userType%3D%27PATIENT%27%20and%20firstName%20%21%20%27%25test%25%22%20%7D
												response = invokeurl
												[
													url :apiUrl
													type :GET
													headers:{"Authorization":"Bearer " + bearerToken,"accept":"*/*"}
												];
												responseMap = response.toMap();
												//alert " |1| " + responseMap.get("status") + responseMap.get("data") + " | " + responseMap.get("error");
												if(responseMap.get("status") == 401 || responseMap.get("status") == 403 || responseMap.containKey("error"))
												{
													retStatus = thisapp.fn_getapitoken();
													//alert "Entering token api call | "+retStatus;
													if(retStatus.get("msg") == "Success")
													{
														tokenRec = App_Config[config_key == "EMR_BEARER_TOKEN"];
														bearerToken = tokenRec.config_value;
														response = invokeurl
														[
															url :apiUrl
															type :GET
															headers:{"Authorization":"Bearer " + bearerToken,"accept":"*/*"}
														];
														responseMap = response.toMap();
													}
													else
													{
														alert retStatus.get("msg");
													}
												}
												//alert " |2| " + retStatus +" | "+responseMap.get("status") + responseMap.get("data") + " | " + responseMap.get("error");
												if(responseMap.get("status") != 401 || responseMap.get("status") != 403 || responseMap.containKey("error") == false)
												{
													contentList = responseMap.get("content");
													input.Patient_Results.clear();
													if(contentList != null && contentList.size() > 0)
													{
														for each  patient in contentList
														{
															patientMap = patient.toMap();
															firstName = patientMap.get("firstName");
															if(firstName == null)
															{
																firstName = "";
															}
															lastName = patientMap.get("lastName");
															if(lastName == null)
															{
																lastName = "";
															}
															fullName = (firstName + " " + lastName).trim();
															displayPatientId = patientMap.get("displayPatientId");
															if(displayPatientId == null)
															{
																displayPatientId = "";
															}
															patientRecordId = "";
															patientRecordId = patientMap.get("id");
															hospitalIdsRaw = patientMap.get("hospitalIds");
															if(hospitalIdsRaw != null)
															{
																hospitalIdsMap = hospitalIdsRaw.toMap();
																uid = hospitalIdsMap.get("uniqueId");
																if(uid != null)
																{
																	uniqueId = uid.toString();
																}
															}
															ageVal = patientMap.get("age");
															ageStr = if(ageVal != null,ageVal.toString(),"");
															genderVal = patientMap.get("gender");
															if(genderVal == null)
															{
																genderVal = "";
															}
															else
															{
																genderVal = genderVal.proper();
															}
															phoneVal = patientMap.get("primaryNumber");
															if(phoneVal == null)
															{
																phoneVal = "";
															}
															addressMap = patientMap.get("address").toMap().get("permanentAddress").toMap();
															resultRow = kit_issues.Patient_Results();
															resultRow.pr_select=false;
															resultRow.pr_name=fullName;
															resultRow.pr_patient_id=displayPatientId;
															resultRow.pr_uhid=uniqueId;
															resultRow.pr_age=ageStr;
															resultRow.pr_gender=genderVal;
															resultRow.pr_phone=phoneVal;
															resultRow.patient_ref_id1=patientRecordId;
															resultRow.Address.address_line_1=addressMap.get("addressLine1");
															resultRow.Address.address_line_2=addressMap.get("addressLine2");
															if(addressMap.get("city") != null || addressMap.get("city").trim() != "")
															{
																resultRow.Address.district_city=addressMap.get("city").toMap().get("name");
															}
															else
															{
																resultRow.Address.district_city=addressMap.get("district");
															}
															if(addressMap.get("pincode") != null || addressMap.get("pincode").trim() != "")
															{
																resultRow.Address.postal_Code=addressMap.get("pincode");
															}
															if(addressMap.get("country") != null || addressMap.get("country").trim() != "")
															{
																resultRow.Address.country=addressMap.get("country");
															}
															if(addressMap.get("state") != null || addressMap.get("state").trim() != "")
															{
																resultRow.Address.state_province=addressMap.get("state").toMap().get("name");
															}
															input.Patient_Results.insert(resultRow);
														}
														disable Patient_Results.pr_name;
														disable Patient_Results.pr_patient_id;
														disable Patient_Results.pr_uhid;
														disable Patient_Results.pr_age;
														disable Patient_Results.pr_gender;
														disable Patient_Results.pr_phone;
														disable Patient_Results.Address;
														hide Patient_Results.Address;
														disable Patient_Results.pr_patient_id;
														hide Patient_Results.pr_patient_id;
													}
													else
													{
														alert "No patients found for '" + searchText + "'.";
													}
												}
												else
												{
													alert "Response eroror for '" + searchText + "'.";
												}
											}
										}
						)
					}
				}

			}
			kit_patient_select as "kit_patient_select"
			{
				type =  form
				form = kit_issues

				record event = on add or edit

				on user input of Patient_Results.pr_select
				{
					actions 
					{
						custom deluge script
						(
											if(row.pr_select == true)
										{
											input.patient_name = row.pr_name;
											input.uhid = row.pr_uhid;
											if(row.pr_age != null && row.pr_age != "")
											{
												input.age = row.pr_age.toLong();
											}
											genderRaw = row.pr_gender;
											if(genderRaw != null && genderRaw.trim() != "")
											{
												input.gender = genderRaw.proper();
											}
											else
											{
												input.gender = "Other";
											}
											if(row.pr_phone != null && row.pr_phone.trim() != "")
											{
												input.phone1 = row.pr_phone;
											}
											if(row.Address.address_line_1 != null && row.Address.address_line_1.trim() != "")
											{
												input.address.address_line_1 = row.Address.address_line_1;
											}
											if(row.Address.address_line_2 != null && row.Address.address_line_2.trim() != "")
											{
												input.address.address_line_2 = row.Address.address_line_2;
											}
											if(row.Address.district_city != null && row.Address.district_city.trim() != "")
											{
												input.address.district_city = row.Address.district_city;
											}
											if(row.Address.postal_Code != null && row.Address.postal_Code.trim() != "")
											{
												input.address.postal_Code = row.Address.postal_Code;
											}
											if(row.Address.country != null && row.Address.country.trim() != "")
											{
												input.address.country = row.Address.country;
											}
											if(row.Address.state_province != null && row.Address.state_province.trim() != "")
											{
												input.address.state_province = row.Address.state_province;
											}
											for each  r in input.Patient_Results
											{
												if(r.pr_patient_id != row.pr_patient_id)
												{
													r.pr_select=false;
												}
											}
										}
						)
					}
				}

			}
