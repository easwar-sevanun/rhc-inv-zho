			kit_onboarding as "kit_onboarding"
			{
				type =  form
				form = kit_issues

				record event = on edit

				on success
				{
					actions  (Blueprint.Current_Stage == "Kit Assigned")
					{
						custom deluge script
						(
											if(input.Blueprint.Current_Stage == "Kit Assigned")
										{
											if(input.onboarding_date1 != null)
											{
												input.notes = "";
												ret = thisapp.fn_kit_onboard(input.ID);
												if(ret != "Success")
												{
													input.notes = " | Kit onboarding failed | " + input.notes + ret;
													thisapp.blueprint.changeStage("kit_issues","kit_issue_and_return_process","Kit Assigned",input.ID);
													input.onboarding_date1 = null;
													input.device_ref_id1 = null;
												}
												else
												{
													input.notes = "Onboarding Success";
												}
												//kd = kit_issues[ID == input.ID];
											}
											else
											{
												input.notes = "Onboarding date missing";
											}
										}
						)
					}
				}

			}
			kit_offboarding as "kit_offboarding"
			{
				type =  form
				form = kit_issues

				record event = on edit

				on success
				{
					actions  (Blueprint.Current_Stage == "Kit In Use" || Blueprint.Current_Stage == "Kit Returned Early")
					{
						custom deluge script
						(
											input.notes = "";
										//to be deleted
										if(input.offboarding_date1 != null)
										{
											reasonText = ifnull(input.return_reason1,"").trim();
											reasonKey = reasonText.toLowerCase();
											reasonId = 0;
											if(reasonKey == "recovered")
											{
												reasonId = 1;
											}
											else if(reasonKey == "deceased")
											{
												reasonId = 2;
											}
											else if(reasonKey == "opted-out" || reasonKey == "opted out" || reasonKey == "optedout")
											{
												reasonId = 3;
											}
											else if(reasonKey == "faulty")
											{
												reasonId = 4;
											}
											else if(reasonKey == "unused")
											{
												reasonId = 5;
											}
											ret = thisapp.fn_kit_offboard(input.ID,reasonId);
											//ret = "Success";//TO BE DELETED
											if(ret != "Success")
											{
												input.notes = ret;
												input.offboarding_date1 = null;
												input.return_reason1 = null;
												kitstage = if(input.Blueprint.Current_Stage == "Kit In Use","Kit In Use","Kit Returned Early");
												thisapp.blueprint.changeStage("kit_issues","kit_issue_and_return_process",kitstage,input.ID);
											}
										}
										//kd = kit_issues[ID == input.ID];
										input.notes = if(ret == "Success",thisapp.errMsg(ret),"Offboarding Success");
						)
					}
				}

			}
			set_serialnumber_devuniqu as "set_serialnumber_devuniqueid"
			{
				type =  form
				form = inventory_items

				record event = on add or edit

				on user input of serial_number
				{
					actions 
					{
						custom deluge script
						(
											bc = input.serial_number.replaceAll("\n","").trim();
