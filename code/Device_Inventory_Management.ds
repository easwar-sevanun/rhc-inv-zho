										{
											newRow = Kit_View.Peripheral_Items();
											newRow.Peripheral_Type=Peripheral_Type[ID == kiRow.Peripheral_Type].peripheral_type;
											newRow.Inventory_Item=inventory_items[ID == kiRow.inventory_items].serial_number;
											input.Peripheral_Items.insert(newRow);
										}
										for each  row in input.Peripheral_Items
										{
											disable Peripheral_Items.Peripheral_Type;
											disable Peripheral_Items.Inventory_Item;
										}
						)
					}
				}

			}
