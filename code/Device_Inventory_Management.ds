			sim_cards_status_guard as "sim_cards_status_guard"
			{
				type =  form
				form = sim_cards

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.ID != null)
										{
											oldSim = sim_cards[ID == input.ID];
											if(oldSim.count() > 0)
											{
												if(oldSim.status != "IN HUB" && input.status == "IN HUB")
												{
													alert "Status cannot be changed from ACTIVE to IN HUB here. This has to be done from Hub SIM Assignment or the Inventory Items form.";
													cancel submit;
												}
												if(oldSim.status == "IN HUB" && input.status != "IN HUB")
												{
													assignCount = hub_sim_assignments[sim_card == input.ID].count();
													if(assignCount > 0)
													{
														alert "SIM is still tied to a hub. Remove hub mapping before changing status to ACTIVE.";
														cancel submit;
													}
												}
											}
										}
						)
					}
				}

			}
