	reports
	{
		kanban inventory_items_by_status
		{
			displayName = "Statuses"
			show all rows from inventory_items    
			(
				device_category as "Device Category"
				internal_barcode as "Barcode"
				asset_tag as "Asset Tag"
				serial_number as "Serial Number"
				device_unique_id as "Device Unique ID"
				hw_version as "Hardware Version"
