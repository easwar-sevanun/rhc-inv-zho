			Kit_Replace_AutoID4 as "Kit_Replace_AutoID"
			{
				type =  form
				form = Total_Kit_Replacement

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											year_val = zoho.currentdate.toString("yyyy");
										month_val = zoho.currentdate.toString("MM");
										count_val = Kit_Replace[replace_id != ""].count() + 1;
										input.replace_id = "KTL-" + year_val + "-" + month_val + "-" + count_val.toString("000");
										disable replace_id;
										disable kit_ref;
										disable Kit_Distribution_ID;
										disable Kit_Status;
										//disable old_bag;
										//disable old_hub;
										disable loss_checked_on;
										disable loss_checked_by;
										disable Kit_Distribution_Status;
										//hide Kit_Distribution_Status;
										// input.kit_ref is set from initial value = "${kit_ref}" URL param before on load fires
										if(input.kit_ref != null)
										{
											kd = kit_issues[provision_id == input.Kit_Distribution_ID && kit.ID == input.kit_ref];
											if(kd.count() > 0)
											{
												input.Kit_Status = kd.distribution_status;
												kt = kit[ID == input.kit_ref];
												lk = Collection();
												if(kt.count() > 0)
												{
													ktRow = Total_Kit_Replacement.Old_Kit();
													ktRow.kit_ref=kt.kit_code;
													ktRow.Bag=bags[ID == kt.bag1].bag_tag;
													ktRow.status=kt.kit_status;
													ktRow.Hub=inventory_items[ID == kt.hub_item1 && device_category == "HUB"].serial_number;
													lk.insert(ktRow);
													input.Old_Kit.clear();
													input.Old_Kit.insert(lk);
													disable Old_Kit.Bag;
													disable Old_Kit.Hub;
													disable Old_Kit.status;
													disable Old_Kit.kit_ref;
												}
											}
										}
						)
					}
				}

			}
			total_replace_onsubmissio as "total_replace_onsubmission"
			{
				type =  form
				form = Total_Kit_Replacement

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											kd = kit_issues[provision_id = input.Kit_Distribution_ID && kit.ID = input.kit_ref];
										lastKDStatusAllocated = kd.distribution_status == "ALLOCATED";
										kd.notes="Kit " + kd.distribution_status + ": Reason:" + input.replacement_reason + " | Notes:" + input.notes + " | Kit ID:" + input.kit_ref.kit_code + " Replaced with:" + input.kit.kit_code + "| reported on " + zoho.currentdate.toString("dd-MMM-yyyy");
										kd.distribution_status="ALLOCATED";
										kitRec = kit[ID = input.kit];
										invItem = inventory_items[ID = kitRec.hub_item1];
										if(invItem != null)
										{
											reasonId = 0;
											reasonText = ifnull(kd.return_reason1,"").trim();
											reasonKey = reasonText.toLowerCase();
											if(reasonKey.contains("recovered"))
											{
												reasonId = 1;
											}
											else if(reasonKey.contains("deceased") || reasonKey.contains("passed away"))
											{
												reasonId = 2;
											}
											else if(reasonKey.contains("opted-out") || reasonKey.contains("opted out") || reasonKey.contains("optedout"))
											{
												reasonId = 3;
											}
											else if(reasonKey.contains("faulty"))
											{
												reasonId = 4;
											}
											else if(reasonKey.contains("unused"))
											{
												reasonId = 5;
											}
											ret = thisapp.fn_hub_reassign(kitRec.hub_item1,kd.patient_ref_id1,input.date_of_reissue1,input.date_of_reissue1,reasonId);
											if(ret.get("code") == 200)
											{
												kd.notes=kd.notes + " | " + thisapp.errMsg(ret.get("message"));
												kd.kit=input.kit;
												kd.replacement_date1=input.date_of_reissue1;
												kd.device_ref_id1=ret.get("device_record_id");
												if(input.replacement_reason == "Patient Request")
												{
													thisapp.fn_setKitStatus(input.kit_ref,"INVENTORY");
												}
												else
												{
													thisapp.fn_setKitStatus(input.kit_ref,"LOST");
												}
												thisapp.fn_setKitStatus(input.kit,"ALLOCATED");
											}
											else
											{
												kd.notes=thisapp.errMsg("Reassign failed");
											}
										}
										else
										{
											kd.notes=thisapp.errMsg("Reassign failed - Inventory hub missing");
										}
										/*
										 				 				if(lastKDStatusAllocated)
										 				 				{
										 				 					thisapp.fn_setKitStatus(input.kit_ref,"INVENTORY");
										 				 				}
										 				 				else
										 				 				{
										 				 					thisapp.fn_setKitStatus(input.kit_ref,"LOST");
										 				 				}*/
						)
					}
				}

			}
