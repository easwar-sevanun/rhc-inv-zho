			locSet as "locSet"
			{
				type =  form
				form = kit

				record event = on add or edit

				on user input of kit_status
				{
					actions 
					{
						custom deluge script
						(
											if(input.kit_status = "ALLOCATED")
										{
											input.location1 = Location[location_name == "Patient"].ID;
										}
						)
					}
				}

