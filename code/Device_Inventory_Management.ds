		form kit
		{
			displayname = "New Kit"
			success message = "Kit Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			kit_code
			(
    			type = text
				displayname = "Kit Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
			bag1
			(
				type = picklist	
				displayname = "Bag"
				values  = bags[status == "IN STOCK"].ID
    			displayformat = [bag_tag]
				allow new entries
				[
					displayname = "Add New"
					set values
					(
						bag_tag = input.bag1
					)
				]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
