						custom deluge script
						(
											if(row.old_inventory_item != null)
										{
											alert "Row for " + row.old_inventory_item.serial_number + " cannot be deleted. Use remove item checkbox to remove from kit.";
											reRow = Kit_Replace.Replace_Items();
											reRow.Peripheral_Type=row.Peripheral_Type;
											reRow.old_inventory_item=row.old_inventory_item;
											reRow.new_inventory_item=row.new_inventory_item;
											reRow.old_item_condition=row.old_item_condition;
											reRow.old_item_new_status=row.old_item_new_status;
											input.Replace_Items.insert(reRow);
										}
						)
					}
				}

			}
